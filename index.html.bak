<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>⚠️ Essential AI Governance Training & Certification Platform - CSGA Global</title>
    <meta name="description" content="In under 200 hours, learn to implement comprehensive AI governance frameworks. Designed for professionals, executives, and CISOs responsible for organizational AI safety.">
    
    <!-- Open Graph -->
    <meta property="og:title" content="⚠️ Essential AI Governance Training & Certification Platform">
    <meta property="og:description" content="CASA certification: 200 hours to expertise, $150K+ salaries, 95% job placement. Defense-grade AI governance training.">
    <meta property="og:image" content="https://csga-global.org/visual_assets/og_image_main.jpg">
    
    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet">
    
    <!-- CSS -->
    <link rel="stylesheet" href="/css/csga-branding.css">
    <link rel="stylesheet" href="/css/kimi-brand-identity.css">
    <link rel="stylesheet" href="/css/bmcc-excellence-styles.css">
    
    <!-- Critical Styles -->
    <style>
        :root {
            --csga-navy: #0A1628;
            --cyber-blue: #1E5AF5;
            --security-teal: #00D4AA;
            --alliance-white: #FFFFFF;
            --alert-red: #EF4444;
            --warning-amber: #F59E0B;
            --neural-purple: #8B5CF6;
            --surface-1: #0F1D32;
            --surface-2: #152238;
            --gradient-primary: linear-gradient(135deg, #1E5AF5 0%, #00D4AA 100%);
        }
        
        * { margin: 0; padding: 0; box-sizing: border-box; }
        
        body { 
            font-family: 'Inter', system-ui, sans-serif; 
            background: var(--csga-navy);
            color: white;
            line-height: 1.6;
        }
        
        .hero-halt {
            position: relative;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            background: 
                linear-gradient(135deg, rgba(10, 22, 40, 0.95) 0%, rgba(30, 41, 59, 0.95) 100%),
                url('./hero_images/main_hero_4k.jpg') center/cover no-repeat;
            background-attachment: fixed;
            text-align: center;
            padding: 80px 20px 20px;
        }
        
        .threat-level-badge {
            position: absolute;
            top: 100px;
            left: 50%;
            transform: translateX(-50%);
            background: var(--alert-red);
            color: white;
            padding: 12px 24px;
            border-radius: 25px;
            font-weight: 700;
            font-size: 0.9rem;
            animation: threatPulse 2s ease-in-out infinite;
            box-shadow: 0 4px 15px rgba(239, 68, 68, 0.4);
        }
        
        @keyframes threatPulse {
            0%, 100% { transform: translateX(-50%) scale(1); opacity: 1; }
            50% { transform: translateX(-50%) scale(1.05); opacity: 0.9; }
        }
        
        .hero-content-halt {
            max-width: 800px;
            margin: 0 auto;
            position: relative;
            z-index: 10;
        }
        
        .warning-title {
            font-size: clamp(2.2rem, 5vw, 4rem);
            font-weight: 900;
            margin-bottom: 20px;
            background: linear-gradient(135deg, #ffffff 0%, #f1f5f9 50%, #e2e8f0 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }
        
        .certification-box {
            background: rgba(239, 68, 68, 0.1);
            border: 2px solid var(--alert-red);
            border-radius: 15px;
            padding: 30px;
            margin: 30px 0;
            backdrop-filter: blur(10px);
        }
        
        .cert-title {
            color: white;
            font-size: 1.8rem;
            font-weight: 800;
            margin-bottom: 15px;
            letter-spacing: -0.5px;
        }
        
        .cert-promise {
            color: rgba(255,255,255,0.9);
            font-size: 1.1rem;
            line-height: 1.6;
        }
        
        .governance-domains {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
            gap: 20px;
            margin: 40px 0;
            text-align: center;
        }
        
        .domain-item {
            background: rgba(255, 255, 255, 0.05);
            padding: 20px;
            border-radius: 12px;
            border-left: 3px solid var(--cyber-blue);
            transition: all 0.3s ease;
            cursor: pointer;
        }
        
        .domain-item:hover {
            background: rgba(30, 90, 245, 0.1);
            transform: translateY(-3px);
        }
        
        .domain-emoji {
            font-size: 2rem;
            margin-bottom: 10px;
        }
        
        .domain-title {
            color: white;
            font-weight: 600;
            margin-bottom: 8px;
            font-size: 0.95rem;
        }
        
        .domain-desc {
            color: rgba(255,255,255,0.8);
            font-size: 0.85rem;
        }
        
        .halt-cta-group {
            display: flex;
            gap: 20px;
            justify-content: center;
            flex-wrap: wrap;
            margin: 40px 0;
        }
        
        .btn-halt-primary {
            background: var(--gradient-primary);
            color: white;
            padding: 18px 36px;
            font-size: 1.1rem;
            font-weight: 700;
            border-radius: 8px;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            transition: all 0.2s ease;
        }
        
        .btn-halt-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 25px rgba(30, 90, 245, 0.4);
        }
        
        .btn-halt-secondary {
            background: transparent;
            color: white;
            border: 2px solid var(--cyber-blue);
            padding: 16px 36px;
            font-size: 1.1rem;
            font-weight: 600;
            border-radius: 8px;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            transition: all 0.2s ease;
        }
        
        .btn-halt-secondary:hover {
            background: rgba(30, 90, 245, 0.1);
            transform: translateY(-2px);
        }
        
        .team-pricing-notice {
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid rgba(255, 255, 255, 0.2);
            border-radius: 12px;
            padding: 20px;
            margin-top: 30px;
            text-align: center;
        }
        
        .audience-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
            gap: 20px;
            margin: 30px 0;
            background: var(--surface-1);
            padding: 25px;
            border-radius: 12px;
            border: 1px solid var(--surface-2);
        }
        
        .audience-item {
            text-align: center;
            color: white;
        }
        
        .audience-emoji {
            font-size: 1.5rem;
            margin-bottom: 8px;
        }
        
        .audience-title {
            font-weight: 600;
            margin-bottom: 4px;
            font-size: 0.9rem;
        }
        
        .audience-desc {
            font-size: 0.8rem;
            color: rgba(255,255,255,0.7);
        }
        
        @media (max-width: 768px) {
            .threat-level-badge {
                position: relative;
                top: 0;
                transform: none;
                margin-bottom: 20px;
                display: inline-block;
            }
            
            .halt-cta-group {
                flex-direction: column;
                align-items: center;
            }
            
            .btn-halt-primary,
            .btn-halt-secondary {
                width: 100%;
                max-width: 280px;
                justify-content: center;
            }
            
            .governance-domains {
                grid-template-columns: 1fr;
                gap: 15px;
            }
        }
    </style>
</head>
<body>
    <!-- Navigation -->
    <nav style="position: fixed; top: 0; width: 100%; background: rgba(10, 22, 40, 0.95); backdrop-filter: blur(10px); z-index: 1000; padding: 12px 0; border-bottom: 1px solid rgba(255,255,255,0.1);">
        <div style="max-width: 1200px; margin: 0 auto; padding: 0 20px; display: flex; align-items: center; justify-content: space-between;">
            <div style="display: flex; align-items: center; gap: 12px; color: white; font-weight: 700;">
                <span style="font-size: 1.5rem;">🛡️</span>
                <span>CSGA Global</span>
            </div>
            <div style="display: flex; align-items: center; gap: 25px;">
                <a href="/casa" style="color: rgba(255,255,255,0.8); text-decoration: none; font-weight: 500;">CASA Cert</a>
                <a href="/mcp" style="color: rgba(255,255,255,0.8); text-decoration: none; font-weight: 500;">MCPs</a>
                <a href="/contact" style="background: var(--gradient-primary); color: white; padding: 8px 16px; border-radius: 20px; text-decoration: none; font-weight: 600;">Get Started</a>
            </div>
        </div>
    </nav>

    <!-- HALT-Style Hero -->
    <section class="hero-halt">
        <div class="threat-level-badge">
            ⚠️ AI Governance Risk Level: CRITICAL
        </div>
        
        <div class="hero-content-halt">
            <h1 class="warning-title">
                <span style="color: var(--alert-red); font-size: 1.2em;">⚠️</span> 
                Essential AI Governance<br>
                <span style="color: white; font-size: 0.85em;">Training & Certification</span>
            </h1>
            
            <div class="certification-box">
                <h2 class="cert-title">CASA AI Governance Certification</h2>
                <p class="cert-promise">
                    In under <strong>200 hours</strong>, learn to implement and defend comprehensive AI governance frameworks. 
                    Designed for <strong>professionals, executives, and CISOs</strong> responsible for organizational AI safety.
                </p>
            </div>
            
            <div class="governance-domains">
                <div class="domain-item">
                    <div class="domain-emoji">🛡️</div>
                    <div class="domain-title">AI Risk Assessment</div>
                    <div class="domain-desc">Enterprise risk evaluation</div>
                </div>
                
                <div class="domain-item">
                    <div class="domain-emoji">📊</div>
                    <div class="domain-title">Regulatory Compliance</div>
                    <div class="domain-desc">ISO 42001 & GDPR alignment</div>
                </div>
                
                <div class="domain-item">
                    <div class="domain-emoji">🔐</div>
                    <div class="domain-title">Security Framework Design</div>
                    <div class="domain-desc">Defense-grade protocols</div>
                </div>
                
                <div class="domain-item">
                    <div class="domain-emoji">⚖️</div>
                    <div class="domain-title">Ethics & Constitutional AI</div>
                    <div class="domain-desc">Responsible AI deployment</div>
                </div>
                
                <div class="domain-item">
                    <div class="domain-emoji">🎯</div>
                    <div class="domain-title">Incident Response</div>
                    <div class="domain-desc">AI failure management</div>
                </div>
                
                <div class="domain-item">
                    <div class="domain-emoji">📋</div>
                    <div class="domain-title">Governance Playbook</div>
                    <div class="domain-desc">Implementation toolkit</div>
                </div>
            </div>
            
            <div class="halt-cta-group">
                <a href="/casa" class="btn-halt-primary">
                    Get CASA Certified →
                </a>
                <a href="/contact" class="btn-halt-secondary">
                    Book Consultation →
                </a>
            </div>
            
            <div class="audience-grid">
                <div class="audience-item">
                    <div class="audience-emoji">👔</div>
                    <div class="audience-title">Executives & CISOs</div>
                    <div class="audience-desc">Strategic AI governance oversight</div>
                </div>
                
                <div class="audience-item">
                    <div class="audience-emoji">🛡️</div>
                    <div class="audience-title">Security Professionals</div>
                    <div class="audience-desc">AI threat detection & response</div>
                </div>
                
                <div class="audience-item">
                    <div class="audience-emoji">⚖️</div>
                    <div class="audience-title">Compliance Officers</div>
                    <div class="audience-desc">Regulatory implementation</div>
                </div>
                
                <div class="audience-item">
                    <div class="audience-emoji">🏢</div>
                    <div class="audience-title">Enterprise Leaders</div>
                    <div class="audience-desc">AI responsibility management</div>
                </div>
            </div>
            
            <div class="team-pricing-notice">
                <div style="margin-bottom: 15px;">
                    <strong>Enterprise & Team Training Available</strong>
                </div>
                <div style="display: flex; gap: 15px; justify-content: center; flex-wrap: wrap;">
                    <a href="/contact" style="background: var(--gradient-primary); color: white; padding: 12px 24px; border-radius: 8px; text-decoration: none; font-weight: 600;">Team Pricing Available</a>
                    <a href="/enterprise" style="background: transparent; color: var(--cyber-blue); border: 1px solid var(--cyber-blue); padding: 12px 24px; border-radius: 8px; text-decoration: none; font-weight: 600;">Enterprise Solutions</a>
                </div>
            </div>
        </div>
    </section>

    <!-- Time-Based Guarantees Section -->
    <section style="background: var(--surface-1); padding: 60px 0; text-align: center;">
        <div style="max-width: 900px; margin: 0 auto; padding: 0 20px;">
            <h3 style="color: white; font-size: 1.8rem; font-weight: 700; margin-bottom: 40px;">
                Fast-Track Your <span style="color: var(--cyber-blue);">AI Governance Expertise</span>
            </h3>
            
            <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 40px; margin-bottom: 40px;">
                <div style="background: linear-gradient(135deg, var(--cyber-blue) 0%, var(--security-teal) 100%); color: white; padding: 30px; border-radius: 15px;">
                    <div style="font-size: 3rem; font-weight: 900; margin-bottom: 8px;">4</div>
                    <div style="font-size: 1rem; opacity: 0.9; margin-bottom: 4px;">weeks to certification</div>
                    <div style="font-size: 0.8rem; opacity: 0.7;">Full CASA program</div>
                </div>
                
                <div style="background: linear-gradient(135deg, var(--security-teal) 0%, var(--neural-purple) 100%); color: white; padding: 30px; border-radius: 15px;">
                    <div style="font-size: 3rem; font-weight: 900; margin-bottom: 8px;">24</div>
                    <div style="font-size: 1rem; opacity: 0.9; margin-bottom: 4px;">hours for implementation</div>
                    <div style="font-size: 0.8rem; opacity: 0.7;">Framework deployment</div>
                </div>
                
                <div style="background: linear-gradient(135deg, var(--neural-purple) 0%, var(--alert-red) 100%); color: white; padding: 30px; border-radius: 15px;">
                    <div style="font-size: 3rem; font-weight: 900; margin-bottom: 8px;">100%</div>
                    <div style="font-size: 1rem; opacity: 0.9; margin-bottom: 4px;">compliance guarantee</div>
                    <div style="font-size: 0.8rem; opacity: 0.7;">Money-back promise</div>
                </div>
            </div>
            
            <div style="background: rgba(30, 90, 245, 0.1); border: 1px solid var(--cyber-blue); padding: 20px; border-radius: 12px; margin-top: 30px;">
                <strong style="color: var(--cyber-blue);">Fast-Track Option:</strong> 
                <span style="color: white;">Complete core modules in 2 weeks with intensive 1-on-1 mentoring from industry experts</span>
            </div>
        </div>
    </section>

    <!-- Scripts -->
    <script src="/js/kimi-design.js"></script>
    <script src="/js/bmcc-excellence.js"></script>
    <script src="/js/bmcc-precise.js"></script>
    
    <script>
        // HALT-style interactions
        document.addEventListener('DOMContentLoaded', function() {
            // Domain item hover effects
            const domainItems = document.querySelectorAll('.domain-item');
            domainItems.forEach(item => {
                item.addEventListener('click', () => {
                    // Track domain interest
                    const domain = item.querySelector('.domain-title').textContent;
                    console.log('Domain interest:', domain);
                    
                    // Add selected state
                    domainItems.forEach(d => d.style.borderLeftColor = 'var(--cyber-blue)');
                    item.style.borderLeftColor = 'var(--security-teal)';
                });
            });
            
            // CTA tracking
            const ctaButtons = document.querySelectorAll('.btn-halt-primary, .btn-halt-secondary');
            ctaButtons.forEach(btn => {
                btn.addEventListener('click', function() {
                    const action = this.textContent.trim();
                    console.log('HALT CTA clicked:', action);
                    
                    // Add click feedback
                    this.style.transform = 'translateY(-2px) scale(0.98)';
                    setTimeout(() => {
                        this.style.transform = 'translateY(-2px)';
                    }, 150);
                });
            });
            
            // Threat level animation
            const threatBadge = document.querySelector('.threat-level-badge');
            if (threatBadge) {
                setInterval(() => {
                    threatBadge.style.boxShadow = '0 4px 20px rgba(239, 68, 68, 0.6)';
                    setTimeout(() => {
                        threatBadge.style.boxShadow = '0 4px 15px rgba(239, 68, 68, 0.4)';
                    }, 500);
                }, 3000);
            }
        });
    </script>
</body>
</html>
