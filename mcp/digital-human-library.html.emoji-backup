<!-- PROBLEM SECTION -->
<section class="sf-problem reveal">
 <div class="container">
 <h2 class="professional-title section-title text-center reveal" class="section-title" class="professional-title" class="professional-title">The Challenge</h2>
 <div class="grid grid-3 reveal">
  <div class="card-professional">
   <h3 class="professional-title professional-title" class="professional-title">­ Identity Theft via Digital Doubles</h3>
   <p class="professional-body">Unauthorized creation and exploitation of digital twins puts individuals at risk of identity fraud, reputation damage, and financial loss through impersonation.</p>
  </div>
  <div class="card-professional">
   <h3 class="professional-title professional-title" class="professional-title">ś Consent for Synthetic Personas</h3>
   <p class="professional-body">AI-generated synthetic personas replicate real individuals without explicit consent, raising ethical and legal concerns about autonomy and personal rights.</p>
  </div>
  <div class="card-professional">
   <h3 class="professional-title professional-title" class="professional-title">– Posthumous Digital Rights</h3>
   <p class="professional-body">Managing digital identity after death lacks clear governance frameworks, leaving families without control over digital legacies and memorialization protocols.</p>
  </div>
 </div>
 </div>
</section>

<!-- SOLUTION SECTION -->
<section class="sf-solution reveal">
 <div class="container">
 <h2 class="professional-title section-title text-center reveal" class="section-title" class="professional-title" class="professional-title">Our Solution</h2>
 <div class="grid grid-3 gap-lg reveal">
  <div class="card-professional">
   <div class="feature-icon-professional">FTR</div>
   <h4>Digital Twin Governor</h4>
   <p class="professional-body">Ensures ethical use, consent verification, and rights management for all digital twins with multi-party verification, audit trails, and access controls.</p>
  </div>
  <div class="card-professional">
   <div class="feature-icon-professional">FTR</div>
   <h4>Synthetic Persona Auditor</h4>
   <p class="professional-body">Audits AI-generated personas for bias, authenticity, and regulatory compliance with automated detection of unauthorized synthetic replicas.</p>
  </div>
  <div class="card-professional">
   <div class="feature-icon-professional">FTR</div>
   <h4>Digital Identity Validator</h4>
   <p class="professional-body">Validates digital identity preservation and posthumous rights protocols with executor designation, heritage management, and memorialization controls.</p>
  </div>
 </div>
 </div>
</section>

<!-- HOW IT WORKS -->
