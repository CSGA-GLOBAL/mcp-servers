<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Constitutional AI-Enhanced COBOL Bridge MCP | Enterprise Legacy Integration | CSGA</title>
  <meta name="description" content="Constitutional AI-powered bridge for legacy COBOL mainframes to modern AI governance infrastructure. Enterprise-grade integration for banking, insurance, and government systems. CASA certified.">
  <meta name="keywords" content="COBOL bridge, Constitutional AI, mainframe integration, AI governance, CASA certification, CICS, JCL, enterprise legacy">
  <meta name="author" content="CSGA - Cyber Security Global Alliance">
  
  <!-- Open Graph / Social Media Meta Tags -->
  <meta property="og:type" content="website">
  <meta property="og:site_name" content="CSGA - Cyber Security Global Alliance">
  <meta property="og:title" content="Constitutional AI-Enhanced COBOL Bridge MCP | Enterprise Legacy Integration">
  <meta property="og:description" content="Constitutional AI-powered bridge for legacy COBOL mainframes to modern AI governance infrastructure. CASA certified enterprise solution.">
  <meta property="og:image" content="/images/cobol-bridge-social.png">
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:site" content="@CSGAGlobal">
  
  <!-- Structured Data for SEO -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    "name": "COBOL Bridge MCP",
    "description": "Constitutional AI-powered bridge for legacy COBOL mainframes to modern AI governance infrastructure",
    "publisher": {
      "@type": "Organization",
      "name": "CSGA - Cyber Security Global Alliance",
      "url": "https://csga-global.org"
    },
    "applicationCategory": "Enterprise Software",
    "operatingSystem": "Cross-platform",
    "offers": {
      "@type": "Offer",
      "price": "4999",
      "priceCurrency": "USD",
      "priceValidUntil": "2026-12-31"
    }
  }
  </script>
  
  <!-- CSGA Professional Fonts -->
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet">
  
  <!--  CSGA Core Branding -->
  <link rel="stylesheet" href="/csga-branding.css">
  
  <!--  CSGA Hero & Mobile Fixes -->
  <link rel="stylesheet" href="/csga-hero-mobile-fixes.css">
  
  <!--  CSGA Inner Pages Professional Enhancement -->
  <link rel="stylesheet" href="/csga-inner-pages-enhancement.css">
  
  <style>
    /* COBOL Bridge Specific Styling */
    :root {
      --cobol-primary: #1a202c;
      --cobol-accent: #3182ce;
      --cobol-success: #059669;
      --cobol-warning: #d97706;
      --cobol-danger: #dc2626;
      --cobol-neutral: #6b7280;
      --cobol-bg-light: #f8fafc;
      --cobol-bg-dark: #0f172a;
    }

    /* Constitutional AI Enhancement Banner */
    .constitutional-banner {
      background: linear-gradient(135deg, rgba(49,130,206,0.08) 0%, rgba(30,58,138,0.08) 100%);
      border: 2px solid rgba(49,130,206,0.2);
      border-left: 6px solid #3182ce;
      border-radius: 12px;
      padding: 32px;
      margin: 48px 0;
      text-align: center;
      position: relative;
      overflow: hidden;
    }

    .constitutional-banner::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background: url('data:image/svg+xml,<svg width="60" height="60" viewBox="0 0 60 60" xmlns="http://www.w3.org/2000/svg"><g fill="none" fill-rule="evenodd"><g fill="%233182ce" fill-opacity="0.04"><rect x="0" y="0" width="2" height="2"/><rect x="58" y="58" width="2" height="2"/></g></svg>') repeat;
      opacity: 0.6;
    }

    .constitutional-banner * {
      position: relative;
      z-index: 2;
    }

    .constitutional-badges {
      display: flex;
      gap: 12px;
      justify-content: center;
      flex-wrap: wrap;
      margin-bottom: 20px;
    }

    .constitutional-badge {
      background: linear-gradient(135deg, #3182ce, #1e40af);
      color: white;
      padding: 8px 16px;
      border-radius: 20px;
      font-size: 0.85rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      box-shadow: 0 2px 8px rgba(49,130,206,0.3);
    }

    /* Hero Section Enhancement */
    .cobol-hero {
      background: linear-gradient(135deg, #0f172a 0%, #1e3a8a 40%, #3182ce 100%);
      color: white;
      padding: 120px 20px 100px;
      text-align: center;
      position: relative;
      overflow: hidden;
      min-height: 600px;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .cobol-hero::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background: 
        radial-gradient(circle at 20% 80%, rgba(49,130,206,0.15) 0%, transparent 50%),
        radial-gradient(circle at 80% 20%, rgba(30,58,138,0.15) 0%, transparent 50%),
        url('data:image/svg+xml,<svg width="80" height="80" viewBox="0 0 80 80" xmlns="http://www.w3.org/2000/svg"><g fill="none" fill-rule="evenodd"><g fill="%23ffffff" fill-opacity="0.05"><circle cx="40" cy="40" r="2"/></g></svg>') repeat;
      animation: float 6s ease-in-out infinite;
    }

    .cobol-hero-content {
      max-width: 900px;
      margin: 0 auto;
      position: relative;
      z-index: 2;
    }

    .cobol-hero-icon {
      font-size: 6rem;
      margin-bottom: 24px;
      display: block;
      animation: pulse 2s ease-in-out infinite;
      filter: drop-shadow(0 4px 20px rgba(0,0,0,0.3));
    }

    .cobol-hero h1 {
      font-family: 'Space Grotesk', 'Inter', system-ui, sans-serif;
      font-size: 4rem;
      font-weight: 800;
      line-height: 1.1;
      margin-bottom: 24px;
      background: linear-gradient(135deg, #ffffff, #93c5fd, #3182ce);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      text-shadow: 0 2px 20px rgba(0,0,0,0.3);
    }

    .cobol-hero-subtitle {
      font-size: 1.4rem;
      color: rgba(255,255,255,0.9);
      line-height: 1.6;
      margin-bottom: 20px;
      max-width: 800px;
      margin-left: auto;
      margin-right: auto;
    }

    .cobol-hero-stats {
      display: flex;
      gap: 40px;
      justify-content: center;
      margin: 40px 0;
      flex-wrap: wrap;
    }

    .cobol-stat {
      text-align: center;
      background: rgba(255,255,255,0.1);
      padding: 20px;
      border-radius: 12px;
      backdrop-filter: blur(10px);
      border: 1px solid rgba(255,255,255,0.2);
    }

    .cobol-stat-number {
      display: block;
      font-size: 2.5rem;
      font-weight: 800;
      font-family: 'Space Grotesk', 'Inter', system-ui, sans-serif;
      color: #93c5fd;
      line-height: 1;
      margin-bottom: 8px;
    }

    .cobol-stat-label {
      font-size: 0.85rem;
      opacity: 0.8;
      text-transform: uppercase;
      letter-spacing: 1px;
      font-weight: 600;
    }

    /* Features Grid Enhancement */
    .cobol-features {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
      gap: 32px;
      max-width: 1400px;
      margin: 0 auto;
    }

    .cobol-feature-card {
      background: linear-gradient(135deg, #ffffff, #f8fafc);
      border: 1px solid rgba(49,130,206,0.1);
      border-radius: 16px;
      padding: 40px;
      transition: all 0.3s ease;
      position: relative;
      overflow: hidden;
      height: 100%;
      display: flex;
      flex-direction: column;
    }

    .cobol-feature-card::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 4px;
      background: linear-gradient(90deg, #3182ce, #1e40af);
      transform: scaleX(0);
      transform-origin: left;
      transition: transform 0.3s ease;
    }

    .cobol-feature-card:hover {
      transform: translateY(-8px);
      box-shadow: 0 20px 40px rgba(49,130,206,0.15);
      border-color: rgba(49,130,206,0.3);
    }

    .cobol-feature-card:hover::before {
      transform: scaleX(1);
    }

    .cobol-feature-icon {
      font-size: 3.5rem;
      margin-bottom: 24px;
      display: flex;
      align-items: center;
      justify-content: center;
      width: 80px;
      height: 80px;
      background: linear-gradient(135deg, #3182ce, #1e40af);
      border-radius: 50%;
      margin-left: auto;
      margin-right: auto;
      box-shadow: 0 8px 24px rgba(49,130,206,0.2);
    }

    .cobol-feature-title {
      font-size: 1.5rem;
      font-weight: 700;
      color: #1a202c;
      margin-bottom: 16px;
      text-align: center;
      font-family: 'Space Grotesk', 'Inter', system-ui, sans-serif;
    }

    .cobol-feature-description {
      color: #4b5563;
      line-height: 1.7;
      text-align: center;
      flex-grow: 1;
      font-size: 1.05rem;
    }

    /* Technical Specifications */
    .cobol-specs {
      background: linear-gradient(135deg, #0f172a, #1e3a8a);
      color: white;
      padding: 80px 20px;
      margin: 80px 0;
      border-radius: 16px;
      position: relative;
      overflow: hidden;
    }

    .cobol-specs::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background: url('data:image/svg+xml,<svg width="100" height="100" viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg"><g fill="none" fill-rule="evenodd"><g fill="%23ffffff" fill-opacity="0.03"><rect x="48" y="48" width="4" height="4"/></g></svg>') repeat;
    }

    .cobol-specs-content {
      max-width: 1200px;
      margin: 0 auto;
      position: relative;
      z-index: 2;
    }

    .cobol-specs-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
      gap: 32px;
      margin-top: 48px;
    }

    .cobol-spec-item {
      background: rgba(255,255,255,0.08);
      backdrop-filter: blur(10px);
      border: 1px solid rgba(255,255,255,0.1);
      border-radius: 12px;
      padding: 32px;
      text-align: center;
    }

    .cobol-spec-label {
      font-size: 0.85rem;
      text-transform: uppercase;
      letter-spacing: 1.5px;
      color: #93c5fd;
      margin-bottom: 8px;
      font-weight: 700;
    }

    .cobol-spec-value {
      font-size: 1.8rem;
      font-weight: 800;
      color: white;
      font-family: 'Space Grotesk', 'Inter', system-ui, sans-serif;
      margin-bottom: 12px;
    }

    .cobol-spec-description {
      color: rgba(255,255,255,0.8);
      font-size: 0.95rem;
      line-height: 1.6;
    }

    /* Integration Patterns */
    .integration-patterns {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
      gap: 32px;
      max-width: 1200px;
      margin: 0 auto;
    }

    .integration-card {
      background: white;
      border: 2px solid #e5e7eb;
      border-radius: 16px;
      padding: 32px;
      position: relative;
      transition: all 0.3s ease;
      text-align: center;
    }

    .integration-card::before {
      content: attr(data-number);
      position: absolute;
      top: -15px;
      left: 50%;
      transform: translateX(-50%);
      background: linear-gradient(135deg, #3182ce, #1e40af);
      color: white;
      width: 40px;
      height: 40px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-weight: 800;
      font-size: 1.2rem;
      box-shadow: 0 4px 16px rgba(49,130,206,0.3);
    }

    .integration-card:hover {
      transform: translateY(-4px);
      box-shadow: 0 16px 32px rgba(49,130,206,0.15);
      border-color: #3182ce;
    }

    .integration-title {
      font-size: 1.3rem;
      font-weight: 700;
      color: #1a202c;
      margin: 20px 0 16px;
      font-family: 'Space Grotesk', 'Inter', system-ui, sans-serif;
    }

    .integration-description {
      color: #4b5563;
      line-height: 1.7;
      font-size: 1.05rem;
    }

    /* Pricing Cards Enhancement */
    .cobol-pricing {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
      gap: 32px;
      max-width: 1200px;
      margin: 0 auto;
    }

    .cobol-price-card {
      background: white;
      border: 2px solid #e5e7eb;
      border-radius: 16px;
      padding: 40px;
      text-align: center;
      position: relative;
      transition: all 0.3s ease;
      height: 100%;
      display: flex;
      flex-direction: column;
    }

    .cobol-price-card.featured {
      border-color: #3182ce;
      background: linear-gradient(135deg, rgba(49,130,206,0.03), white);
      transform: scale(1.05);
    }

    .cobol-price-card.featured::before {
      content: 'MOST POPULAR';
      position: absolute;
      top: -12px;
      left: 50%;
      transform: translateX(-50%);
      background: linear-gradient(135deg, #3182ce, #1e40af);
      color: white;
      padding: 8px 20px;
      border-radius: 20px;
      font-size: 0.75rem;
      font-weight: 800;
      letter-spacing: 1px;
    }

    .cobol-price-card:hover {
      transform: translateY(-8px);
      box-shadow: 0 20px 40px rgba(0,0,0,0.1);
    }

    .cobol-price-tier {
      font-size: 0.9rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 1px;
      color: #3182ce;
      margin-bottom: 16px;
    }

    .cobol-price-amount {
      font-size: 3rem;
      font-weight: 800;
      color: #1a202c;
      font-family: 'Space Grotesk', 'Inter', system-ui, sans-serif;
      margin-bottom: 8px;
    }

    .cobol-price-currency {
      font-size: 1.2rem;
      color: #6b7280;
      font-weight: 400;
    }

    .cobol-price-period {
      font-size: 1rem;
      color: #6b7280;
      margin-bottom: 24px;
    }

    .cobol-price-features {
      list-style: none;
      padding: 0;
      margin: 24px 0;
      flex-grow: 1;
    }

    .cobol-price-features li {
      padding: 12px 0;
      border-bottom: 1px solid #f3f4f6;
      color: #4b5563;
      font-size: 0.95rem;
      position: relative;
      padding-left: 24px;
    }

    .cobol-price-features li::before {
      content: 'ś';
      position: absolute;
      left: 0;
      color: #059669;
      font-weight: 700;
    }

    .cobol-price-button {
      background: linear-gradient(135deg, #3182ce, #1e40af);
      color: white;
      border: none;
      padding: 16px 32px;
      border-radius: 8px;
      font-weight: 700;
      font-size: 1rem;
      text-decoration: none;
      display: inline-block;
      transition: all 0.3s ease;
      margin-top: auto;
    }

    .cobol-price-button:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 24px rgba(49,130,206,0.4);
    }

    /* Case Studies Enhancement */
    .case-studies-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(400px, 1fr));
      gap: 32px;
      max-width: 1200px;
      margin: 0 auto;
    }

    .case-study-card {
      background: white;
      border: 1px solid #e5e7eb;
      border-radius: 16px;
      padding: 32px;
      transition: all 0.3s ease;
      position: relative;
      overflow: hidden;
    }

    .case-study-card::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 4px;
      background: linear-gradient(90deg, #3182ce, #1e40af, #059669);
    }

    .case-study-card:hover {
      transform: translateY(-4px);
      box-shadow: 0 16px 32px rgba(0,0,0,0.1);
    }

    .case-study-industry {
      display: inline-block;
      background: rgba(49,130,206,0.1);
      color: #3182ce;
      padding: 6px 12px;
      border-radius: 6px;
      font-size: 0.75rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 1px;
      margin-bottom: 16px;
    }

    .case-study-title {
      font-size: 1.3rem;
      font-weight: 700;
      color: #1a202c;
      margin-bottom: 16px;
      font-family: 'Space Grotesk', 'Inter', system-ui, sans-serif;
    }

    .case-study-description {
      color: #4b5563;
      line-height: 1.7;
      margin-bottom: 24px;
      font-size: 1.05rem;
    }

    .case-study-metrics {
      display: flex;
      gap: 20px;
      justify-content: space-around;
      padding-top: 20px;
      border-top: 1px solid #f3f4f6;
    }

    .case-study-metric {
      text-align: center;
    }

    .case-study-metric-value {
      font-size: 1.5rem;
      font-weight: 800;
      color: #3182ce;
      font-family: 'Space Grotesk', 'Inter', system-ui, sans-serif;
    }

    .case-study-metric-label {
      font-size: 0.75rem;
      color: #6b7280;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      font-weight: 600;
    }

    /* Mobile Responsive */
    @media (max-width: 768px) {
      .cobol-hero h1 {
        font-size: 2.5rem;
      }
      
      .cobol-hero-stats {
        flex-direction: column;
        align-items: center;
        gap: 20px;
      }
      
      .cobol-features {
        grid-template-columns: 1fr;
      }
      
      .constitutional-badges {
        flex-direction: column;
        align-items: center;
      }
      
      .cobol-pricing {
        grid-template-columns: 1fr;
      }
      
      .cobol-price-card.featured {
        transform: none;
      }
      
      .case-studies-grid {
        grid-template-columns: 1fr;
      }
      
      .integration-patterns {
        grid-template-columns: 1fr;
      }
    }

    /* Animations */
    @keyframes float {
      0%, 100% { transform: translateY(0px); }
      50% { transform: translateY(-10px); }
    }

    @keyframes pulse {
      0%, 100% { transform: scale(1); }
      50% { transform: scale(1.05); }
    }

    @keyframes fadeInUp {
      from { 
        opacity: 0; 
        transform: translateY(30px); 
      }
      to { 
        opacity: 1; 
        transform: translateY(0); 
      }
    }

    .fade-in-up {
      animation: fadeInUp 0.6s ease-out forwards;
    }
  </style>
