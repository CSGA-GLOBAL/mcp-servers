    <link rel="stylesheet" href="/csga-image-optimization.css">
</head>
<body>
    <a href="#main-content" class="skip-to-content">Skip to main content</a>
  <!-- Navigation (imported from shared component) -->
  <div id="site-header"></div>

  <!-- Breadcrumb Navigation -->
  <nav class="breadcrumb-nav" aria-label="Breadcrumb navigation">
    <div class="breadcrumb">
      <a href="/"> CSGA Home</a>
      <span class="breadcrumb-separator">></span>
      <a href="/catalog.html">MCP Catalog</a>
      <span class="breadcrumb-separator">></span>
      <span class="breadcrumb-current">Constitutional AI COBOL Bridge</span>
    </div>
  </nav>

  <!-- Constitutional AI Enhancement Banner -->
  <section class="constitutional-banner">
    <div class="constitutional-badges">
      <span class="constitutional-badge"> Constitutional AI Enhanced</span>
      <span class="constitutional-badge"> Enterprise Integration</span>
      <span class="constitutional-badge"> CASA Certified</span>
      <span class="constitutional-badge"> Real-Time Governance</span>
    </div>
    <h2 class="professional-title section-title" style="color: #1a202c; font-size: 2.2rem; margin-bottom: 16px;" class="professional-title" class="professional-title">
      March 2026: Constitutional AI-Powered Legacy Integration
    </h2>
    <p style="color: #4b5563; font-size: 1.2rem; line-height: 1.6; max-width: 900px; margin: 0 auto 32px;" class="professional-body">
      Bridge 40-year-old COBOL systems to Constitutional AI governance frameworks  the enterprise solution for mainframe compliance in the AI-driven economy
    </p>
    <div style="display: flex; gap: 16px; justify-content: center; flex-wrap: wrap;">
      <a href="/pricing.html" class="btn-professional"> Start $4,999 Trial</a>
      <a href="/contact.html" class="btn-professional"> COBOL Assessment</a>
    </div>
  </section>

  <!-- Hero Section -->
  <section class="cobol-hero">
    <div class="cobol-hero-content">
      <div class="cobol-hero-icon"></div>
      <h1 class="professional-title page-title" class="professional-title" class="professional-title">Constitutional AI COBOL Bridge</h1>
      <p class="cobol-hero-subtitle" class="professional-body">
        Enterprise-grade bridge connecting legacy COBOL mainframes to Constitutional AI governance infrastructure  delivering real-time compliance for banking, insurance, and government systems
      </p>
      
      <div class="cobol-hero-stats">
        <div class="cobol-stat">
          <span class="cobol-stat-number">220B+</span>
          <span class="cobol-stat-label">Lines of COBOL</span>
        </div>
        <div class="cobol-stat">
          <span class="cobol-stat-number">95%</span>
          <span class="cobol-stat-label">ATM Transactions</span>
