    <link rel="stylesheet" href="/csga-perfect-professional-polish.css">
    <!-- đźš¨ EMERGENCY: Hero Readability Fix -->
    <link rel="stylesheet" href="/csga-hero-readability-emergency-fix.css">
    <!-- đź“± EMERGENCY: Mobile Responsiveness Fix -->
    <link rel="stylesheet" href="/csga-mobile-emergency-fix.css">
    <!-- đźŽ¨ EMERGENCY: Color Contrast Fix -->
    <link rel="stylesheet" href="/csga-contrast-emergency-fix.css">
    <!-- đź“ť EMERGENCY: Typography Consistency Fix -->
    <link rel="stylesheet" href="/csga-typography-emergency-fix.css">
    <!-- đźš€ CSGA 2026 Global Styles -->
    <link rel="stylesheet" href="/csga-2026-global-styles.css">
    <link rel="stylesheet" href="/csga-2026-components.css">
    <!-- đźš¨ EMERGENCY FIX: Black text on blue backgrounds -->
    <link rel="stylesheet" href="/csga-homepage-text-emergency-fix.css">
