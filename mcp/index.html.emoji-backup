<!-- FOOTER -->
<script>
  // Mobile menu toggle
  const menuToggle = document.getElementById('menuToggle');
  const navBar = document.getElementById('navBar');

  if (menuToggle) {
    menuToggle.addEventListener('click', () => {
      navBar.classList.toggle('active');
    });
  }

  // Search and filter functionality
  const searchInput = document.getElementById('searchInput');
  const filterBtns = document.querySelectorAll('.filter-btn');
  const mcpCards = document.querySelectorAll('.mcp-card');

  let currentTierFilter = 'all';

  // Search functionality
  searchInput.addEventListener('input', (e) => {
    const query = e.target.value.toLowerCase();
    filterCards(query, currentTierFilter);
  });

  // Tier filter functionality
  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      filterBtns.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      currentTierFilter = btn.getAttribute('data-filter');
      const query = searchInput.value.toLowerCase();
      filterCards(query, currentTierFilter);
    });
  });

  function filterCards(searchQuery, tierFilter) {
    let visibleCount = 0;

    mcpCards.forEach(card => {
      const name = card.getAttribute('data-name').toLowerCase();
      const description = card.getAttribute('data-description').toLowerCase();
      const tier = card.getAttribute('data-tier').toLowerCase();

      const matchesSearch = !searchQuery || name.includes(searchQuery) || description.includes(searchQuery);
      const matchesTier = tierFilter === 'all' || tier === tierFilter;

      if (matchesSearch && matchesTier) {
        card.style.display = '';
        visibleCount++;
      } else {
        card.style.display = 'none';
      }
    });

    // Show no results message if needed
    const sections = document.querySelectorAll('.section');
    sections.forEach(section => {
      const cards = section.querySelectorAll('.mcp-card');
      const visibleCards = Array.from(cards).filter(card => card.style.display !== 'none');

      let noResultsDiv = section.querySelector('.no-results');
      if (visibleCards.length === 0 && cards.length > 0) {
        if (!noResultsDiv) {
          noResultsDiv = document.createElement('div');
          noResultsDiv.className = 'no-results';
          noResultsDiv.innerHTML = '<h3 class="professional-title professional-title" class="professional-title">No MCPs found</h3><p class="professional-body">Try adjusting your search or filter criteria.</p>';
          section.querySelector('.grid-3, .grid-4').parentNode.appendChild(noResultsDiv);
        }
        noResultsDiv.style.display = 'block';
      } else if (noResultsDiv) {
        noResultsDiv.style.display = 'none';
      }
    });
  }
</script>

