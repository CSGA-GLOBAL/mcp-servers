 <style>
/* Blog-specific styling */
 .blog-hero {
 background: linear-gradient(135deg, #0A1628 0%, #0d2847 50%, #0058A4 100%);
 padding: 100px 20px 80px;
 text-align: center;
 color: white;
 margin-bottom: 60px;
 position: relative;
 overflow: hidden;
 }
 .blog-hero::after {
 content: '';
 position: absolute;
 top: 0; left: 0; right: 0; bottom: 0;
 background: radial-gradient(ellipse at 30% 50%, rgba(0,88,164,0.3) 0%, transparent 60%),
 radial-gradient(ellipse at 70% 50%, rgba(204,0,0,0.1) 0%, transparent 50%);
 pointer-events: none;
 }
 .blog-hero > * { position: relative; z-index: 1; }
 .blog-hero h1 {
 font-size: 3.2em;
 font-weight: 800;
 margin: 0 0 20px 0;
 font-family: 'Space Grotesk', 'Inter', system-ui, sans-serif;
 animation: fadeInUp 0.7s ease-out;
 }
 .blog-hero p {
 font-size: 1.2em;
 max-width: 600px;
 margin: 0 auto;
 opacity: 0.9;
 animation: fadeInUp 0.7s ease-out 0.15s both;
 }
 .blog-container {
 max-width: 1280px;
 margin: 0 auto;
 padding: 0 20px;
 }
 .filter-section {
 margin-bottom: 50px;
 display: flex;
 gap: 12px;
 flex-wrap: wrap;
 justify-content: center;
 }
 .filter-btn {
 padding: 10px 22px;
 border: 2px solid #e5e7eb;
 background: white;
 color: #374151;
 border-radius: 25px;
 cursor: pointer;
 font-weight: 500;
 transition: all 0.3s ease;
 font-family: 'Space Grotesk', 'Inter', system-ui, sans-serif;
 }
 .filter-btn:hover {
 border-color: #0058A4;
 color: #0058A4;
 transform: translateY(-2px);
 box-shadow: 0 4px 12px rgba(0,88,164,0.15);
 }
 .filter-btn.active {
 background: linear-gradient(135deg, #0A1628, #0058A4);
 color: white;
 border-color: transparent;
 box-shadow: 0 4px 16px rgba(0,88,164,0.3);
 }
 .blog-grid {
 display: grid;
 grid-template-columns: repeat(3, 1fr);
 gap: 30px;
 margin-bottom: 60px;
 }
 .blog-card {
 background: white;
 border: 1px solid #e5e7eb;
 border-radius: 16px;
 padding: 30px;
 transition: all 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
 position: relative;
 overflow: hidden;
 }
 .blog-card::before {
 content: '';
 position: absolute;
 top: 0; left: 0; right: 0;
 height: 4px;
 background: linear-gradient(90deg, #3182ce, #0058A4);
 transform: scaleX(0);
 transform-origin: left;
 transition: transform 0.4s ease;
 }
 .blog-card:hover {
 box-shadow: 0 20px 60px rgba(0,0,0,0.1);
 transform: translateY(-8px);
 border-color: rgba(0,88,164,0.2);
 }
 .blog-card:hover::before {
 transform: scaleX(1);
 }
 .blog-card-header {
 margin-bottom: 15px;
 }
 .category-badge {
 display: inline-block;
 padding: 6px 12px;
 border-radius: 6px;
 color: white;
 font-size: 0.85em;
 font-weight: 600;
 }
 .blog-card-title {
 font-size: 1.3em;
 font-weight: 700;
 margin: 15px 0;
 color: #1f2937;
 font-family: 'Space Grotesk', 'Inter', system-ui, sans-serif;
 }
 .blog-card-excerpt {
 color: #6b7280;
 font-size: 0.95em;
 line-height: 1.6;
 margin-bottom: 15px;
 }
 .blog-card-meta {
 display: flex;
 gap: 15px;
 font-size: 0.85em;
 color: #9ca3af;
 margin-bottom: 20px;
 }
 .blog-card-link {
 color: #0058A4;
 text-decoration: none;
 font-weight: 600;
 display: inline-block;
 margin-top: 10px;
 transition: all 0.3s ease;
 }
 .blog-card-link:hover {
 color: #3182ce;
 letter-spacing: 0.5px;
 }
 .newsletter-cta {
 background: linear-gradient(135deg, #0A1628 0%, #0d2847 60%, #0058A4 100%);
 padding: 80px 40px;
 border-radius: 20px;
 text-align: center;
 color: white;
 margin-bottom: 60px;
 position: relative;
 overflow: hidden;
 }
 .newsletter-cta::before {
 content: '';
 position: absolute;
 top: 0; left: 0; right: 0; bottom: 0;
 background: radial-gradient(ellipse at 50% 0%, rgba(204,0,0,0.15) 0%, transparent 60%);
 pointer-events: none;
 }
 .newsletter-cta > * { position: relative; z-index: 1; }
 .newsletter-cta h2 {
 font-size: 2.4em;
 margin: 0 0 15px 0;
 font-family: 'Space Grotesk', 'Inter', system-ui, sans-serif;
 }
 .newsletter-form {
 display: flex;
 gap: 10px;
 max-width: 500px;
 margin: 20px auto 0;
 }
 .newsletter-form input {
 flex: 1;
 padding: 14px 20px;
 border: none;
 border-radius: 12px;
 font-family: 'Space Grotesk', 'Inter', system-ui, sans-serif;
 font-size: 1em;
 }
 .newsletter-form button {
 padding: 14px 32px;
 background: linear-gradient(135deg, #3182ce, #c49a45);
 color: #0A1628;
 border: none;
 border-radius: 12px;
 font-weight: 700;
 cursor: pointer;
 transition: all 0.3s ease;
 font-family: 'Space Grotesk', 'Inter', system-ui, sans-serif;
 }
 .newsletter-form button:hover {
 transform: translateY(-2px);
 box-shadow: 0 8px 24px rgba(204,0,0,0.4);
 }
 @media (max-width: 768px) {
 .blog-grid {
 grid-template-columns: 1fr;
 }
 .blog-hero h1 {
 font-size: 2em;
 }
 .filter-section {
 justify-content: flex-start;
 }
 .newsletter-form {
 flex-direction: column;
 }
 }
 .blog-card.hidden {
 display: none;
 }
</style>
