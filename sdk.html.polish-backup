<!-- AUTHENTICATION SECTION -->
<section style="background: #ffffff;">
  <div class="container">
    <div style="text-align: center; margin-bottom: 60px;">
      <span class="section-label">Security</span>
      <h2 class="professional-title section-title" class="section-title" class="professional-title">Authentication & Authorization</h2>
      <p class="section-subtitle" class="professional-body">Enterprise-grade security for all API interactions and integrations.</p>
    </div>

    <div class="grid grid-2" style="margin-bottom: 48px;">
      <div class="card-professional">
        <h3 class="professional-title"><h3 class="professional-title" class="professional-title">API Keys</h3>
        <p class="professional-body">Simple API keys for development and testing. Scoped to specific resources and actions.</p>
        <div class="code-block">Authorization: Bearer YOUR_API_KEY</div>
        <p style="margin-top: 16px; font-size: 0.9rem;" class="professional-body">Best for: Development, server-to-server auth</p>
      </div>

      <div class="card-professional">
        <h3 class="professional-title"><h3 class="professional-title" class="professional-title">OAuth 2.0</h3>
        <p class="professional-body">Industry-standard OAuth 2.0 for user-facing applications and third-party integrations.</p>
        <div class="code-block">grant_type=authorization_code
&code=AUTH_CODE
&client_id=YOUR_CLIENT_ID</div>
        <p style="margin-top: 16px; font-size: 0.9rem;" class="professional-body">Best for: User-facing apps, SaaS</p>
      </div>

      <div class="card-professional">
        <h3 class="professional-title"><h3 class="professional-title" class="professional-title">JWT Tokens</h3>
        <p class="professional-body">JSON Web Tokens for stateless authentication and fine-grained access control.</p>
        <div class="code-block">Authorization: Bearer eyJhbGc...</div>
        <p style="margin-top: 16px; font-size: 0.9rem;" class="professional-body">Best for: Microservices, API gateways</p>
      </div>

      <div class="card-professional">
        <h3 class="professional-title"><h3 class="professional-title" class="professional-title">mTLS Certificates</h3>
        <p class="professional-body">Mutual TLS for ultra-secure server-to-server communication in regulated environments.</p>
        <div class="code-block">client_cert.pem + client_key.pem</div>
        <p style="margin-top: 16px; font-size: 0.9rem;" class="professional-body">Best for: Classified, on-prem deployments</p>
      </div>
    </div>

    <div style="background: linear-gradient(135deg, rgba(204, 0, 0, 0.05), rgba(230, 57, 70, 0.05)); border-left: 4px solid var(--gold); padding: 24px; border-radius: 12px;">
      <h4 style="color: var(--dark); margin-bottom: 12px;">Security Best Practices</h4>
      <ul style="list-style: none; padding: 0; color: #475569; line-height: 1.8;">
        <li>✓ Rotate API keys every 90 days</li>
        <li>✓ Use environment variables for credentials</li>
        <li>✓ Enable rate limiting and DDoS protection</li>
