<section id="quickstart" style="background: #F8FAFC;">
  <div class="container">
    <div style="text-align: center; margin-bottom: 60px;">
      <span class="section-label">Get Started</span>
      <h2 class="professional-title section-title" class="section-title" class="professional-title">Quickstart Guide</h2>
      <p class="section-subtitle" class="professional-body">Three simple steps to integrate the CSGA MCP Platform into your application.</p>
    </div>

    <div class="grid grid-3">
      <div class="card-professional">
        <div class="icon-circle" style="background: linear-gradient(135deg, rgba(204, 0, 0, 0.15), rgba(230, 57, 70, 0.15));">📦</div>
        <h3 class="professional-title"><h3 class="professional-title" class="professional-title">Installation</h3>
        <p class="professional-body">Install the SDK via npm for your preferred runtime environment.</p>
        <div class="code-block">npm install @csgaglobal/mcp-sdk</div>
      </div>

      <div class="card-professional">
        <div class="icon-circle" style="background: linear-gradient(135deg, rgba(204, 0, 0, 0.15), rgba(230, 57, 70, 0.15));"><div class="feature-icon-professional">CFG</div></div>
        <h3 class="professional-title"><h3 class="professional-title" class="professional-title">Initialize</h3>
        <p class="professional-body">Set up your connection to the CSGA platform with API credentials.</p>
        <div class="code-block">const mcp = new MCPClient({
  apiKey: process.env.CSGA_API_KEY,
  endpoint: 'https://api.csga.global'
});</div>
      </div>

      <div class="card-professional">
        <div class="icon-circle" style="background: linear-gradient(135deg, rgba(204, 0, 0, 0.15), rgba(230, 57, 70, 0.15));">🔑</div>
        <h3 class="professional-title"><h3 class="professional-title" class="professional-title">Authenticate</h3>
        <p class="professional-body">Use API keys or OAuth 2.0 for secure authentication.</p>
        <div class="code-block">const token = await mcp.auth.login({
  apiKey: YOUR_API_KEY
});</div>
      </div>
    </div>
  </div>
</section>

<!-- API REFERENCE SECTION -->
<section style="background: #ffffff;">
  <div class="container">
    <div style="text-align: center; margin-bottom: 60px;">
      <span class="section-label">API Reference</span>
      <h2 class="professional-title section-title" class="section-title" class="professional-title">Available APIs</h2>
      <p class="section-subtitle" class="professional-body">Build powerful integrations with our comprehensive REST API endpoints.</p>
    </div>

    <div class="grid grid-2">
      <div class="card-professional">
        <div class="icon-circle">🖥️</div>
        <h3 class="professional-title"><h3 class="professional-title" class="professional-title">MCP Server API</h3>
        <p class="professional-body">Deploy, manage, and orchestrate MCP servers. Full CRUD operations for your server ecosystem.</p>
        <p style="color: #0058A4; font-weight: 600; margin-top: 16px;" class="professional-body">GET /api/v1/mcps</p>
        <p style="font-size: 0.9rem; color: #666;" class="professional-body">Retrieve all available MCP servers with metadata and capabilities.</p>
      </div>

      <div class="card-professional">
        <div class="icon-circle">🏛️</div>
        <h3 class="professional-title"><h3 class="professional-title" class="professional-title">Governance API</h3>
        <p class="professional-body">Manage policies, compliance checks, and governance rules across your MCP infrastructure.</p>
        <p style="color: #0058A4; font-weight: 600; margin-top: 16px;" class="professional-body">POST /api/v1/policies</p>
        <p style="font-size: 0.9rem; color: #666;" class="professional-body">Create and enforce governance policies for AI safety.</p>
      </div>

      <div class="card-professional">
        <div class="icon-circle"><div class="feature-icon-professional">SHD</div></div>
        <h3 class="professional-title"><h3 class="professional-title" class="professional-title">Security API</h3>
        <p class="professional-body">Vulnerability scanning, threat intelligence feeds, and security posture management.</p>
        <p style="color: #0058A4; font-weight: 600; margin-top: 16px;" class="professional-body">POST /api/v1/scan</p>
        <p style="font-size: 0.9rem; color: #666;" class="professional-body">Scan MCPs for vulnerabilities and security compliance.</p>
      </div>

      <div class="card-professional">
        <div class="icon-circle">🔔</div>
        <h3 class="professional-title"><h3 class="professional-title" class="professional-title">Webhook API</h3>
        <p class="professional-body">Real-time event notifications for deployment, policy, and security events.</p>
        <p style="color: #0058A4; font-weight: 600; margin-top: 16px;" class="professional-body">POST /api/v1/webhooks</p>
        <p style="font-size: 0.9rem; color: #666;" class="professional-body">Register webhook endpoints for event-driven architecture.</p>
      </div>

      <div class="card-professional">
        <div class="icon-circle"><div class="feature-icon-professional">ANL</div></div>
        <h3 class="professional-title"><h3 class="professional-title" class="professional-title">Analytics API</h3>
        <p class="professional-body">Usage metrics, audit logs, and detailed analytics for your MCP infrastructure.</p>
        <p style="color: #0058A4; font-weight: 600; margin-top: 16px;" class="professional-body">GET /api/v1/analytics</p>
        <p style="font-size: 0.9rem; color: #666;" class="professional-body">Monitor performance and usage patterns across MCPs.</p>
      </div>

      <div class="card-professional">
        <div class="icon-circle">💾</div>
        <h3 class="professional-title"><h3 class="professional-title" class="professional-title">Data API</h3>
        <p class="professional-body">Query and manage data across your MCP ecosystem with enterprise-grade consistency.</p>
        <p style="color: #0058A4; font-weight: 600; margin-top: 16px;" class="professional-body">GET /api/v1/data</p>
        <p style="font-size: 0.9rem; color: #666;" class="professional-body">Access unified data layer across all MCP servers.</p>
      </div>
    </div>
  </div>
</section>

