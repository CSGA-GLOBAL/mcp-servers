        <style>
        /* 🎨 CSGA Visual Perfection System */
        
        /* Typography Excellence */
        body {
            font-family: 'Space Grotesk', system-ui, -apple-system, sans-serif;
            font-optical-sizing: auto;
            text-rendering: optimizeLegibility;
            -webkit-font-smoothing: antialiased;
            -moz-osx-font-smoothing: grayscale;
            line-height: 1.6;
            color: #1e293b;
        }
        
        /* Perfect Heading Hierarchy */
        h1, h2, h3, h4, h5, h6 {
            font-weight: 700;
            line-height: 1.3;
            margin-bottom: 1rem;
            background: linear-gradient(135deg, #1e40af, #3b82f6);
            background-clip: text;
            -webkit-background-clip: text;
            color: transparent;
        }
        
        h1 { font-size: clamp(2rem, 5vw, 3.5rem); }
        h2 { font-size: clamp(1.5rem, 4vw, 2.5rem); }
        h3 { font-size: clamp(1.25rem, 3vw, 2rem); }
        
        /* Perfect Spacing System */
        .page-header {
            padding: 4rem 0 2rem;
            background: linear-gradient(135deg, #0f172a, #1e293b);
            color: white;
            text-align: center;
        }
        
        .page-title {
            color: white !important;
            background: linear-gradient(135deg, #3b82f6, #06b6d4);
            background-clip: text;
            -webkit-background-clip: text;
            margin-bottom: 0.5rem;
        }
        
        .page-subtitle {
            font-size: 1.2rem;
            opacity: 0.9;
            margin-bottom: 0;
        }
        
        /* Breadcrumb Excellence */
        .breadcrumb-nav {
            padding: 1rem 0;
            background: rgba(248, 250, 252, 0.8);
            backdrop-filter: blur(10px);
        }
        
        .breadcrumb {
            display: flex;
            list-style: none;
            margin: 0;
            padding: 0;
            font-size: 0.9rem;
        }
        
        .breadcrumb-item + .breadcrumb-item::before {
            content: '→';
            margin: 0 0.5rem;
            color: #64748b;
        }
        
        .breadcrumb-item a {
            color: #3b82f6;
            text-decoration: none;
            transition: color 0.3s ease;
        }
        
        .breadcrumb-item a:hover {
            color: #1e40af;
        }
        
        .breadcrumb-item.active {
            color: #64748b;
            font-weight: 600;
        }
        
        /* Skip Navigation */
        .skip-navigation {
            position: absolute;
            top: -100px;
            left: 1rem;
            background: #1e40af;
            color: white;
            padding: 0.5rem 1rem;
            text-decoration: none;
            border-radius: 0 0 0.5rem 0.5rem;
            transition: top 0.3s ease;
            z-index: 1000;
        }
        
        .skip-navigation:focus {
            top: 0;
        }
        
        /* Contextual CTA Excellence */
        .contextual-cta {
            background: linear-gradient(135deg, #f8fafc, #e2e8f0);
            padding: 3rem 0;
            margin: 3rem 0;
            text-align: center;
            border-radius: 1rem;
            border: 1px solid rgba(59, 130, 246, 0.1);
        }
        
        .cta-content h3 {
            font-size: 1.75rem;
            margin-bottom: 1rem;
        }
        
        .cta-content p {
            font-size: 1.1rem;
            color: #64748b;
            margin-bottom: 2rem;
            max-width: 600px;
            margin-left: auto;
            margin-right: auto;
        }
        
        /* Perfect Button System */
        .btn-primary {
            background: linear-gradient(135deg, #3b82f6, #1e40af);
            color: white;
            padding: 1rem 2rem;
            border: none;
            border-radius: 0.5rem;
            font-weight: 600;
            text-decoration: none;
            display: inline-block;
            transition: all 0.3s ease;
            box-shadow: 0 4px 15px rgba(59, 130, 246, 0.4);
        }
        
        .btn-primary:hover {
            background: linear-gradient(135deg, #2563eb, #1d4ed8);
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(59, 130, 246, 0.6);
            text-decoration: none;
            color: white;
        }
        
        /* Content Excellence */
        .container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 1rem;
        }
        
        section {
            padding: 2rem 0;
        }
        
        p {
            margin-bottom: 1.5rem;
            font-size: 1.1rem;
            line-height: 1.7;
        }
        
        /* Mobile Excellence */
        @media (max-width: 768px) {
            .page-header {
                padding: 2rem 0 1rem;
            }
            
            .contextual-cta {
                margin: 2rem 0;
                padding: 2rem 1rem;
            }
            
            .btn-primary {
                display: block;
                text-align: center;
                margin: 0 auto;
                max-width: 300px;
            }
        }
        
        /* Accessibility Excellence */
        @media (prefers-reduced-motion: reduce) {
            *, *::before, *::after {
                animation-duration: 0.01ms !important;
                animation-iteration-count: 1 !important;
                transition-duration: 0.01ms !important;
            }
        }
        
        /* Focus Management */
        :focus {
            outline: 2px solid #3b82f6;
            outline-offset: 2px;
        }
        
        /* Print Optimization */
        @media print {
            .contextual-cta, .breadcrumb-nav, .skip-navigation {
                display: none;
            }
        }
        </style>

        <style>
        /* 🏛️ CSGA Real Logo Implementation */
        .CSGA-logo-container {
            display: flex;
            align-items: center;
            gap: 1rem;
        }
        
        .CSGA-logo {
            height: 48px;
            width: auto;
            filter: brightness(1.1);
            transition: transform 0.3s ease;
        }
        
        .CSGA-logo:hover {
            transform: scale(1.05);
        }
        
        .CSGA-tagline {
            font-size: 0.9rem;
            font-weight: 600;
            color: #64748b;
            letter-spacing: 0.5px;
            text-transform: uppercase;
        }
        
        /* Header Logo */
        .header .CSGA-logo {
            height: 40px;
        }
        
        /* Footer Logo */
        .footer .CSGA-logo {
            height: 36px;
            opacity: 0.8;
        }
        
        /* Mobile Logo */
        @media (max-width: 768px) {
            .CSGA-logo-container {
                flex-direction: column;
                gap: 0.5rem;
                text-align: center;
            }
            
            .CSGA-logo {
                height: 36px;
            }
            
            .CSGA-tagline {
                font-size: 0.8rem;
            }
        }
        </style>

        <style>
        /* 🎨 CSGA Brand Guidelines Implementation */
        :root {
            --csga-primary: #1e40af;
            --csga-secondary: #3b82f6;
            --csga-accent: #06b6d4;
            --csga-success: #10b981;
            --csga-warning: #f59e0b;
            --csga-danger: #dc2626;
            --csga-dark: #0f172a;
            --csga-light: #f8fafc;
        }
        
        /* Brand Color Application */
        .bg-primary { background-color: var(--csga-primary); }
        .bg-secondary { background-color: var(--csga-secondary); }
        .text-primary { color: var(--csga-primary); }
        .text-secondary { color: var(--csga-secondary); }
        
        /* Brand Typography */
        .brand-heading {
            background: linear-gradient(135deg, var(--csga-primary), var(--csga-secondary));
            background-clip: text;
            -webkit-background-clip: text;
            color: transparent;
            font-weight: 700;
        }
        
        /* CSGA Professional Elements */
        .csga-card {
            border: 1px solid rgba(59, 130, 246, 0.2);
            border-radius: 0.75rem;
            background: white;
            box-shadow: 0 4px 6px rgba(59, 130, 246, 0.1);
            transition: all 0.3s ease;
        }
        
        .csga-card:hover {
            border-color: var(--csga-secondary);
            box-shadow: 0 8px 15px rgba(59, 130, 246, 0.2);
            transform: translateY(-2px);
        }
        
        /* Navigation Brand Styling */
        .navbar {
            background: var(--csga-light);
            border-bottom: 2px solid var(--csga-primary);
        }
        
        .nav-link {
            color: var(--csga-dark);
            font-weight: 500;
            transition: color 0.3s ease;
        }
        
        .nav-link:hover {
            color: var(--csga-primary);
        }
        
        /* Footer Brand Styling */
        .footer {
            background: var(--csga-dark);
            color: white;
            border-top: 3px solid var(--csga-primary);
        }
        </style>
    <link rel="stylesheet" href="/css/mobile-advanced.css">
</head>
