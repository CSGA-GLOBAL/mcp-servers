<!DOCTYPE html>
<html lang="en">
<head>
 <meta charset="UTF-8">
 <meta name="viewport" content="width=device-width, initial-scale=1.0">
 <title>Pricing - CSGA Global</title>
 <meta name="description" content="Simple, transparent pricing for CSGA Global AI governance and cybersecurity solutions.">
 
 
 <style>
.hero-pricing {
 background: linear-gradient(135deg, rgba(0, 88, 164, 0.85), rgba(0, 88, 164, 0.85)),
 url('data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1200 600"><rect fill="%230A1628" width="1200" height="600"/><path fill="%23d4a853" opacity="0.1" d="M0 0 L100 100 L200 0 L300 100 L400 0 L500 100 L600 0 L700 100 L800 0 L900 100 L1000 0 L1100 100 L1200 0 L1200 600 L0 600 Z"/ class="professional-body"></svg>');
 background-size: cover;
 background-position: center;
 padding: 100px 20px;
 text-align: center;
 color: white;
 min-height: 400px;
 display: flex;
 align-items: center;
 justify-content: center;
 }
 .hero-pricing h1 {
 font-family: 'Space Grotesk', 'Inter', system-ui, sans-serif;
 font-size: 3.2rem;
 font-weight: 700;
 margin-bottom: 20px;
 text-shadow: 0 2px 10px rgba(0, 0, 0, 0.3);
 }
 .hero-pricing .subtitle {
 font-size: 1.2rem;
 font-weight: 300;
 max-width: 600px;
 margin: 0 auto;
 color: rgba(255, 255, 255, 0.95);
 }
 .pricing-section {
 padding: 80px 20px;
 background: white;
 }
 .pricing-container {
 max-width: 1200px;
 margin: 0 auto;
 }
 .pricing-cards {
 display: grid;
 grid-template-columns: repeat(4, 1fr);
 gap: 24px;
 margin-bottom: 60px;
 }
 @media (max-width: 1100px) {
 .pricing-cards { grid-template-columns: repeat(2, 1fr) !important; }
 }
 .pricing-card {
 background: white;
 border: 2px solid #ddd;
 border-radius: 12px;
 padding: 40px;
 transition: all 0.25s ease;
 position: relative;
 }
 .pricing-card.featured {
 border-color: #0058A4;
 box-shadow: 0 10px 30px rgba(0, 88, 164, 0.15);
 transform: scale(1.05);
 }
 .pricing-card h3 {
 font-family: 'Space Grotesk', 'Inter', system-ui, sans-serif;
 font-size: 1.5rem;
 color: #0058A4;
 margin-bottom: 10px;
 }
 .pricing-card .description {
 color: #666;
 font-size: 0.9rem;
 margin-bottom: 25px;
 min-height: 40px;
 }
 .price {
 font-size: 2.5rem;
 font-weight: 700;
 color: #3182ce;
 margin-bottom: 10px;
 }
 .price-period {
 color: #999;
 font-size: 0.9rem;
 margin-bottom: 30px;
 }
 .features-list {
 list-style: none;
 padding: 0;
 margin-bottom: 30px;
 }
 .features-list li {
 padding: 10px 0;
 border-bottom: 1px solid #eee;
 color: #555;
 font-size: 0.95rem;
 }
 .features-list li:last-child {
 border-bottom: none;
 }
 .features-list li::before {
 content: '';
 color: #0058A4;
 font-weight: bold;
 margin-right: 10px;
 }
 .pricing-btn {
 width: 100%;
 padding: 12px;
 border: none;
 border-radius: 12px;
 font-weight: 600;
 cursor: pointer;
 transition: all 0.25s ease;
 font-size: 0.95rem;
 }
 .pricing-btn.primary {
 background: #3182ce;
 color: white;
 }
 .pricing-btn.primary:hover {
 background: #b30000;
 transform: translateY(-2px);
 }
 .pricing-btn.secondary {
 background: #f0f4f8;
 color: #0058A4;
 border: 2px solid #3182ce;
 }
 .pricing-btn.secondary:hover {
 background: #3182ce;
 color: white;
 }
 .comparison-section {
 padding: 80px 20px;
 background: #f8f9fa;
 }
 .comparison-container {
 max-width: 1200px;
 margin: 0 auto;
 }
 .comparison-container h2 {
 font-family: 'Space Grotesk', 'Inter', system-ui, sans-serif;
 font-size: 2.2rem;
 color: #0058A4;
 text-align: center;
 margin-bottom: 50px;
 }
 .comparison-table {
 width: 100%;
 background: white;
 border-collapse: collapse;
 border-radius: 12px;
 overflow: hidden;
 box-shadow: 0 4px 15px rgba(0, 0, 0, 0.08);
 }
 .comparison-table th,
 .comparison-table td {
 padding: 20px;
 text-align: left;
 border-bottom: 1px solid #eee;
 }
 .comparison-table th {
 background: #0058A4;
 color: white;
 font-weight: 600;
 }
 .comparison-table tr:last-child td {
 border-bottom: none;
 }
 .comparison-table .feature-name {
 font-weight: 500;
 color: #0058A4;
 }
 .comparison-table .check {
 color: #0058A4;
 font-weight: bold;
 }
 .faq-section {
 padding: 80px 20px;
 background: white;
 }
 .faq-container {
 max-width: 900px;
 margin: 0 auto;
 }
 .faq-container h2 {
 font-family: 'Space Grotesk', 'Inter', system-ui, sans-serif;
 font-size: 2.2rem;
 color: #0058A4;
 text-align: center;
 margin-bottom: 50px;
 }
 .faq-item {
 background: #f8f9fa;
 padding: 25px;
 margin-bottom: 20px;
 border-radius: 12px;
 border-left: 4px solid #3182ce;
 }
 .faq-item h3 {
 color: #0058A4;
 margin-bottom: 12px;
 cursor: pointer;
 font-size: 1rem;
 }
 .faq-item p {
 color: #555;
 font-size: 0.95rem;
 line-height: 1.6;
 margin: 0;
 }
 .cta-pricing-section {
 padding: 80px 20px;
 background: linear-gradient(135deg, #A30000, #3182ce);
 text-align: center;
 color: white;
 }
 .cta-pricing-section h2 {
 font-family: 'Space Grotesk', 'Inter', system-ui, sans-serif;
 font-size: 2.5rem;
 margin-bottom: 30px;
 }
 .cta-button {
 background: #3182ce;
 color: white;
 padding: 15px 40px;
 border: none;
 border-radius: 12px;
 font-size: 1.1rem;
 font-weight: 600;
 cursor: pointer;
 transition: all 0.25s ease;
 text-decoration: none;
 display: inline-block;
 }
 .cta-button:hover {
 background: #b30000;
 transform: translateY(-2px);
 box-shadow: 0 10px 25px rgba(204, 0, 0, 0.3);
 }
 @media (max-width: 768px) {
 .hero-pricing h1 {
 font-size: 2rem;
 }
 .pricing-card.featured {
 transform: scale(1);
 }
 .pricing-cards {
 grid-template-columns: 1fr !important;
 }
 .comparison-table {
 font-size: 0.85rem;
 }
 .comparison-table th,
 .comparison-table td {
 padding: 15px;
 }
 .cta-pricing-section h2 {
 font-size: 1.8rem;
 }
 }
 
/*  Ecosystem Bundles  */
.eco-section{padding:80px 24px;background:#f8fafc}
.eco-container{max-width:1200px;margin:0 auto}
.eco-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:24px}
.eco-card{background:#fff;border-radius:12px;padding:32px 24px;border:2px solid #e8ecf0;transition:all .25s;position:relative}
.eco-card:hover{border-color:#0058A4;transform:translateY(-4px);box-shadow:0 12px 40px rgba(0,88,164,.12)}
.eco-icon{font-size:2.2rem;margin-bottom:12px}
.eco-card h3{font-family: 'Space Grotesk', 'Inter', system-ui, sans-serif;font-size:1.15rem;color:#0A1628;margin-bottom:6px}
.eco-desc{color:#666;font-size:.9rem;margin-bottom:16px}
.eco-price{font-size:2rem;font-weight:700;color:#0058A4;font-family: 'Space Grotesk', 'Inter', system-ui, sans-serif
.eco-price span{font-size:.9rem;font-weight:400;color:#666}
.eco-annual{font-size:.85rem;color:#16a34a;font-weight:500;margin-bottom:16px}
.eco-list{list-style:none;padding:0;margin:0 0 20px}
.eco-list li{padding:5px 0;font-size:.85rem;color:#444;border-bottom:1px solid #f0f2f5}
.eco-list li::before{content:" ";color:#0058A4;font-weight:700}
@media(max-width:900px){.eco-grid{grid-template-columns:repeat(2,1fr)}}
@media(max-width:600px){.eco-grid{grid-template-columns:1fr}}
/*  Per-MCP Pricing  */
.per-mcp-section{padding:80px 24px;background:#fff}
.per-mcp-container{max-width:900px;margin:0 auto}
.per-mcp-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:24px}
.per-mcp-card{background:#fff;border-radius:12px;padding:32px 24px;border:2px solid #e8ecf0;text-align:center;transition:all .25s;position:relative}
.per-mcp-card.featured{border-color:#0058A4;box-shadow:0 8px 32px rgba(0,88,164,.15)}
.per-mcp-card:hover{transform:translateY(-4px);box-shadow:0 12px 40px rgba(0,88,164,.12)}
.per-mcp-tier{display:inline-block;color:#fff;padding:4px 16px;border-radius:4px;font-size:.75rem;font-weight:700;letter-spacing:.5px;margin-bottom:12px}
.per-mcp-card h3{font-family: 'Space Grotesk', 'Inter', system-ui, sans-serif;font-size:1.2rem;color:#0A1628;margin-bottom:8px}
.per-mcp-price{font-size:2.5rem;font-weight:700;color:#0A1628;font-family: 'Space Grotesk', 'Inter', system-ui, sans-serif
.per-mcp-price span{font-size:1rem;font-weight:400;color:#666}
.per-mcp-period{color:#666;font-size:.9rem;margin-bottom:20px}
.per-mcp-list{list-style:none;padding:0;margin:0 0 24px;text-align:left}
.per-mcp-list li{padding:8px 0;font-size:.9rem;color:#444;border-bottom:1px solid #f0f2f5}
.per-mcp-list li::before{content:" ";color:#0058A4;font-weight:700}
@media(max-width:600px){.per-mcp-grid{grid-template-columns:1fr}}
</style>
