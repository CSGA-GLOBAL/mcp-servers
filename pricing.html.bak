<section class="cta-pricing-section csga-section">
 <h2 class="professional-title professional-title" class="professional-title" class="brand-heading">Ready to Get Started?</h2>
 <p style="font-size: 1.1rem; margin-bottom: 16px;" class="professional-body">Start with a membership, ecosystem bundle, or individual MCP  all with free trials included</p>
 <div style="display:inline-flex;align-items:center;gap:8px;background:rgba(16,185,129,.1);padding:8px 20px;border-radius:4px;margin-bottom:24px;"><svg width="18" height="18" viewBox="0 0 24 24" fill="#10B981"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/ class="professional-body"></svg><span style="font-size:.9rem;font-weight:600;color:#10B981;">30-day money-back guarantee · No questions asked</span></div>
 <div style="display:flex;gap:16px;justify-content:center;flex-wrap:wrap">
 <button class="btn-professional" onclick="handleCheckout('community')">Start Free</button>
 <button class="btn-professional" style="background:#0058A4" onclick="handleCheckout('professional')">Try Professional</button>
 <button class="btn-professional" style="background:linear-gradient(135deg,#A30000,#3182ce)" onclick="handleCheckout('enterprise_custom')">Contact Sales</button>
 </div>
</section>

<div id="checkout-modal" style="display:none;position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,.6);z-index:10000;align-items:center;justify-content:center">
 <div style="background:#fff;border-radius:12px;max-width:520px;width:90%;padding:40px;position:relative;box-shadow:0 25px 80px rgba(0,0,0,.3)">
 <button onclick="closeCheckoutModal()" style="position:absolute;top:15px;right:20px;background:none;border:none;font-size:1.5rem;cursor:pointer;color:#666">&times;</button>
 <div id="modal-content"></div>
 </div>
</div>
<script src="/js/pricing-config.js"></script>
<script src="https://js.stripe.com/v3/"></script>
<script>
// 
//  CSGA Global  Pricing Page JavaScript
//  Uses CSGA_PRICING from /js/pricing-config.js
// 
const P = window.CSGA_PRICING || {};
const STRIPE_CFG = P.stripe || {};
let currentBilling = 'monthly';

//  Billing Toggle 
function toggleBilling(mode) {
 currentBilling = mode;
 const mBtn = document.getElementById('toggle-monthly');
 const aBtn = document.getElementById('toggle-annual');
 const isAnnual = mode === 'annual';
 // Toggle button styles
 [mBtn, aBtn].forEach((btn, i) => {
  const active = i === (isAnnual ? 1 : 0);
  btn.style.background = active ? '#0058A4' : '#fff';
  btn.style.color = active ? '#fff' : '#333';
  btn.style.borderColor = active ? '#0058A4' : '#e0e0e0';
 });
 // Update all tier price cards
 document.querySelectorAll('.tier-price').forEach(el => {
  const monthly = el.dataset.monthly;
  const annual = el.dataset.annual;
  if (!monthly) return;
  el.textContent = isAnnual ? `$${Number(annual).toLocaleString()}` : `$${Number(monthly).toLocaleString()}`;
 });
 document.querySelectorAll('.tier-period').forEach(el => {
  el.textContent = isAnnual ? '/ year' : '/ month';
 });
 document.querySelectorAll('.tier-annual-note').forEach(el => {
  el.style.display = isAnnual ? 'block' : 'none';
 });
}

//  Plan info lookup from CSGA_PRICING 
const PLAN_INFO = {};
if (P.memberships) {
 Object.entries(P.memberships).forEach(([key, m]) => {
  PLAN_INFO[key] = {
   name: m.name,
   icon: key === 'community' ? '' : key === 'starter' ? '' : key === 'professional' ? '' : key === 'enterprise_sector' ? '' : key === 'enterprise_full' ? '' : '',
   mcps: m.mcpCount || '?',
   monthly: m.monthlyPrice,
   annual: m.annualPrice,
   credits: m.credits || 0,
   team: m.teamMembers || 1,
   trial: m.trialDays || 0,
  };
 });
}

//  Ecosystem info lookup 
const ECO_INFO = {};
if (P.ecosystems) {
 Object.entries(P.ecosystems).forEach(([key, e]) => {
  ECO_INFO[key] = { name: e.name, monthly: e.monthlyPrice, annual: e.annualPrice, mcps: e.mcps?.length || 0, credits: e.credits };
 });
}

//  Handle checkout for all product types 
function handleCheckout(plan) {
 const modal = document.getElementById('checkout-modal');
 const content = document.getElementById('modal-content');

 //  Community / Free signup 
 if (plan === 'community') {
  content.innerHTML = `
  <div style="text-align:center">
  <div style="font-size:3rem;margin-bottom:15px"></div>
  <h2 style="font-family: 'Space Grotesk', 'Inter', system-ui, sans-serif;color:#0058A4;margin-bottom:10px" class="section-title" class="professional-title" class="professional-title" class="brand-heading">Create Your Free Account</h2>
  <p style="color:#666;margin-bottom:25px" class="professional-body">Access 3 open-source MCPs with 100 API credits/month  no credit card required.</p>
  <form id="free-signup-form" onsubmit="handleFreeSignup(event)" style="text-align:left">
  <div style="margin-bottom:15px">
  <label style="display:block;font-weight:600;margin-bottom:5px;color:#333">Full Name</label>
  <input type="text" name="name" required style="width:100%;padding:12px;border:2px solid #e0e0e0;border-radius:8px;font-size:1rem;box-sizing:border-box" placeholder="Jane Smith">
  </div>
  <div style="margin-bottom:15px">
  <label style="display:block;font-weight:600;margin-bottom:5px;color:#333">Work Email</label>
  <input type="email" name="email" required style="width:100%;padding:12px;border:2px solid #e0e0e0;border-radius:8px;font-size:1rem;box-sizing:border-box" placeholder="jane@company.com">
  </div>
  <div style="margin-bottom:15px">
  <label style="display:block;font-weight:600;margin-bottom:5px;color:#333">Organisation</label>
  <input type="text" name="org" style="width:100%;padding:12px;border:2px solid #e0e0e0;border-radius:8px;font-size:1rem;box-sizing:border-box" placeholder="Acme Corp">
  </div>
  <button type="submit" style="width:100%;padding:14px;background:#0058A4;color:#fff;border:none;border-radius:8px;font-size:1rem;font-weight:600;cursor:pointer;margin-top:10px">Create Free Account</button>
  </form>
  <p style="font-size:.8rem;color:#999;margin-top:15px" class="professional-body">By signing up, you agree to our <a href="/csoai-standards" style="color:#0058A4">Terms of Service</a>.</p>
  </div>`;
 }
 //  Enterprise Custom / Sovereign inquiry 
 else if (plan === 'enterprise_custom') {
  content.innerHTML = `
  <div style="text-align:center">
  <div style="font-size:3rem;margin-bottom:15px"></div>
  <h2 style="font-family: 'Space Grotesk', 'Inter', system-ui, sans-serif;color:#A30000;margin-bottom:10px" class="section-title" class="professional-title" class="professional-title" class="brand-heading">Enterprise Custom / Sovereign</h2>
  <p style="color:#666;margin-bottom:25px" class="professional-body">Self-hosted, air-gapped, FedRAMP-aligned AI governance for government and defence.</p>
  <form id="sovereign-form" onsubmit="handleEnterpriseInquiry(event)" style="text-align:left">
  <div style="margin-bottom:15px">
  <label style="display:block;font-weight:600;margin-bottom:5px;color:#333">Full Name</label>
  <input type="text" name="name" required style="width:100%;padding:12px;border:2px solid #e0e0e0;border-radius:8px;font-size:1rem;box-sizing:border-box">
  </div>
  <div style="margin-bottom:15px">
  <label style="display:block;font-weight:600;margin-bottom:5px;color:#333">Work Email</label>
  <input type="email" name="email" required style="width:100%;padding:12px;border:2px solid #e0e0e0;border-radius:8px;font-size:1rem;box-sizing:border-box">
  </div>
  <div style="margin-bottom:15px">
  <label style="display:block;font-weight:600;margin-bottom:5px;color:#333">Organisation</label>
  <input type="text" name="org" required style="width:100%;padding:12px;border:2px solid #e0e0e0;border-radius:8px;font-size:1rem;box-sizing:border-box">
  </div>
  <div style="margin-bottom:15px">
  <label style="display:block;font-weight:600;margin-bottom:5px;color:#333">Deployment Requirements</label>
  <select name="deployment" style="width:100%;padding:12px;border:2px solid #e0e0e0;border-radius:8px;font-size:1rem;box-sizing:border-box">
  <option>On-Premise (Air-Gapped)</option>
  <option>Private Cloud (FedRAMP)</option>
  <option>Hybrid (Cloud + On-Prem)</option>
  <option>Classified Environment</option>
  </select>
  </div>
  <div style="margin-bottom:15px">
  <label style="display:block;font-weight:600;margin-bottom:5px;color:#333">Additional Details</label>
  <textarea name="requirements" rows="3" style="width:100%;padding:12px;border:2px solid #e0e0e0;border-radius:8px;font-size:1rem;box-sizing:border-box;resize:vertical" placeholder="Compliance requirements, team size, timeline..."></textarea>
  </div>
  <button type="submit" style="width:100%;padding:14px;background:linear-gradient(135deg,#A30000,#3182ce);color:#fff;border:none;border-radius:8px;font-size:1rem;font-weight:600;cursor:pointer">Request Sovereign Demo</button>
  </form>
  </div>`;
 }
 //  COBOL Bridge enterprise / CASA CA-40 (sales contact) 
 else if (plan === 'cobol_enterprise' || plan === 'casa_ca40') {
  const label = plan === 'cobol_enterprise' ? 'COBOL Bridge Enterprise' : 'CASA CA-40 Sovereign';
  content.innerHTML = `
  <div style="text-align:center">
  <div style="font-size:3rem;margin-bottom:15px"></div>
  <h2 style="font-family: 'Space Grotesk', 'Inter', system-ui, sans-serif;color:#0058A4;margin-bottom:10px" class="section-title" class="professional-title" class="professional-title" class="brand-heading">${label}</h2>
  <p style="color:#666;margin-bottom:25px" class="professional-body">This product requires a custom scope discussion with our team.</p>
  <a href="/contact" style="display:inline-block;padding:14px 30px;background:#0058A4;color:#fff;border-radius:8px;text-decoration:none;font-weight:600">Contact Sales</a>
  </div>`;
 }
 //  Paid membership tiers (Starter through Enterprise Full) 
 else if (PLAN_INFO[plan]) {
  const info = PLAN_INFO[plan];
  const isAnnual = currentBilling === 'annual';
  const price = isAnnual ? info.annual : info.monthly;
  const period = isAnnual ? 'yr' : 'mo';
  content.innerHTML = `
  <div style="text-align:center">
  <div style="font-size:3rem;margin-bottom:15px">${info.icon}</div>
  <h2 style="font-family: 'Space Grotesk', 'Inter', system-ui, sans-serif;color:#0058A4;margin-bottom:10px" class="section-title" class="professional-title" class="professional-title" class="brand-heading">${info.name}</h2>
  <p style="color:#666;margin-bottom:20px" class="professional-body">${info.trial}-day free trial, then:</p>
  <div style="display:flex;gap:10px;justify-content:center;margin-bottom:25px">
  <button onclick="switchModalBilling('${plan}','monthly')" style="padding:10px 24px;border-radius:8px;border:2px solid ${!isAnnual?'#0058A4':'#e0e0e0'};background:${!isAnnual?'#0058A4':'#fff'};color:${!isAnnual?'#fff':'#333'};font-weight:600;cursor:pointer">Monthly  $${info.monthly.toLocaleString()}/mo</button>
  <button onclick="switchModalBilling('${plan}','annual')" style="padding:10px 24px;border-radius:8px;border:2px solid ${isAnnual?'#0058A4':'#e0e0e0'};background:${isAnnual?'#0058A4':'#fff'};color:${isAnnual?'#fff':'#333'};font-weight:600;cursor:pointer;position:relative">Annual  $${info.annual.toLocaleString()}/yr <span style="background:#3182ce;color:#fff;padding:2px 8px;border-radius:8px;font-size:.7rem;margin-left:5px">Save 20%</span></button>
  </div>
  <ul style="text-align:left;list-style:none;padding:0;margin-bottom:25px">
  <li style="padding:8px 0;border-bottom:1px solid #f0f0f0"> ${info.mcps} MCP tools</li>
  <li style="padding:8px 0;border-bottom:1px solid #f0f0f0"> ${typeof info.credits === 'number' ? info.credits.toLocaleString() : info.credits} API credits/month</li>
  <li style="padding:8px 0;border-bottom:1px solid #f0f0f0"> ${info.team === 'unlimited' ? 'Unlimited' : info.team} team member${info.team === 1 ? '' : 's'}</li>
  <li style="padding:8px 0;border-bottom:1px solid #f0f0f0"> Stripe billing portal</li>
  <li style="padding:8px 0"> ${info.trial}-day free trial included</li>
  </ul>
  <button id="stripe-checkout-btn" onclick="initiateStripeCheckout('${plan}','${isAnnual ? 'annual' : 'monthly'}')" style="width:100%;padding:14px;background:#0058A4;color:#fff;border:none;border-radius:8px;font-size:1rem;font-weight:600;cursor:pointer">Start ${info.trial}-Day Free Trial</button>
  <p style="font-size:.8rem;color:#999;margin-top:12px" class="professional-body"> Secured by Stripe. Cancel anytime during trial.</p>
  </div>`;
 }
 //  Ecosystem bundles 
 else if (plan.startsWith('ecosystem_')) {
  const ecoKey = plan.replace('ecosystem_', '');
  const eco = ECO_INFO[ecoKey];
  if (eco) {
   const isAnnual = currentBilling === 'annual';
   const price = isAnnual ? eco.annual : eco.monthly;
   content.innerHTML = `
   <div style="text-align:center">
   <div style="font-size:3rem;margin-bottom:15px"></div>
   <h2 style="font-family: 'Space Grotesk', 'Inter', system-ui, sans-serif;color:#0058A4;margin-bottom:10px" class="section-title" class="professional-title" class="professional-title" class="brand-heading">${eco.name} Bundle</h2>
   <p style="color:#666;margin-bottom:20px" class="professional-body">${eco.mcps} MCPs · ${eco.credits.toLocaleString()} credits/mo</p>
   <div style="font-size:2rem;font-weight:700;color:#0A1628;margin-bottom:5px">$${price.toLocaleString()}<span style="font-size:1rem;color:#666;font-weight:400">/${isAnnual ? 'yr' : 'mo'}</span></div>
   <button id="stripe-checkout-btn" onclick="initiateStripeCheckout('ecosystem_${ecoKey}','${isAnnual ? 'annual' : 'monthly'}')" style="width:100%;padding:14px;background:#0058A4;color:#fff;border:none;border-radius:8px;font-size:1rem;font-weight:600;cursor:pointer;margin-top:20px">Subscribe Now</button>
   <p style="font-size:.8rem;color:#999;margin-top:12px" class="professional-body"> Secured by Stripe. 14-day free trial included.</p>
   </div>`;
  }
 }
 //  Credit packs, COBOL, CASA (one-time or subscription) 
 else if (plan.startsWith('credits_') || plan.startsWith('cobol_') || plan.startsWith('casa_')) {
  let label, price, mode;
  if (plan === 'credits_starter') { label = '1,000 API Credits'; price = 9; mode = 'payment'; }
  else if (plan === 'credits_pro') { label = '5,000 API Credits'; price = 29; mode = 'payment'; }
  else if (plan === 'credits_enterprise') { label = '25,000 API Credits'; price = 99; mode = 'payment'; }
  else if (plan === 'cobol_basic') { label = 'COBOL Bridge Basic'; price = 999; mode = 'subscription'; }
  else if (plan === 'cobol_pro') { label = 'COBOL Bridge Pro'; price = 2499; mode = 'subscription'; }
  else if (plan === 'casa_ca10') { label = 'CASA CA-10 Foundation'; price = 2500; mode = 'payment'; }
  else if (plan === 'casa_ca20') { label = 'CASA CA-20 Intermediate'; price = 7500; mode = 'payment'; }
  else if (plan === 'casa_ca30') { label = 'CASA CA-30 Advanced'; price = 15000; mode = 'payment'; }
  else { label = plan; price = 0; mode = 'payment'; }
  content.innerHTML = `
  <div style="text-align:center">
  <div style="font-size:3rem;margin-bottom:15px">${plan.startsWith('credits') ? '' : plan.startsWith('cobol') ? '' : ''}</div>
  <h2 style="font-family: 'Space Grotesk', 'Inter', system-ui, sans-serif;color:#0058A4;margin-bottom:10px" class="section-title" class="professional-title" class="professional-title" class="brand-heading">${label}</h2>
  <div style="font-size:2.5rem;font-weight:700;color:#0A1628;margin:15px 0">$${price.toLocaleString()}</div>
  <p style="color:#666;margin-bottom:25px" class="professional-body">${mode === 'payment' ? 'One-time purchase' : 'Per month subscription'}</p>
  <button id="stripe-checkout-btn" onclick="initiateStripeCheckout('${plan}','${mode}')" style="width:100%;padding:14px;background:#0058A4;color:#fff;border:none;border-radius:8px;font-size:1rem;font-weight:600;cursor:pointer">${mode === 'payment' ? 'Purchase Now' : 'Subscribe Now'}</button>
  <p style="font-size:.8rem;color:#999;margin-top:12px" class="professional-body"> Secured by Stripe.</p>
  </div>`;
 }
 modal.style.display = 'flex';
 document.body.style.overflow = 'hidden';
}

function switchModalBilling(plan, billing) {
 currentBilling = billing;
 closeCheckoutModal();
 handleCheckout(plan);
}
function closeCheckoutModal() {
 document.getElementById('checkout-modal').style.display = 'none';
 document.body.style.overflow = '';
}
document.getElementById('checkout-modal').addEventListener('click', function(e) {
 if (e.target === this) closeCheckoutModal();
});

//  Stripe Checkout Session 
async function initiateStripeCheckout(productKey, billingOrMode) {
 const btn = document.getElementById('stripe-checkout-btn');
 btn.textContent = 'Redirecting to Stripe...';
 btn.disabled = true;

 // Resolve productKey + billing to a real Stripe priceId using CSGA_PRICING config
 let priceId = null;
 let checkoutMode = 'subscription';
 let trialDays = null;
 let metadata = {};

 // Check memberships (e.g. 'starter', 'professional', 'enterprise_sector', 'enterprise_full')
 const mem = CSGA_PRICING.memberships[productKey];
 if (mem) {
  priceId = billingOrMode === 'annual' ? mem.stripePriceAnnual : mem.stripePriceMonthly;
  checkoutMode = 'subscription';
  trialDays = mem.trialDays || null;
  metadata = { tier: productKey, productType: 'membership' };
 }

 // Check ecosystem bundles (e.g. 'ecosystem_security', 'ecosystem_governance')
 if (!priceId && productKey.startsWith('ecosystem_')) {
  const ecoKey = productKey.replace('ecosystem_', '');
  const eco = CSGA_PRICING.ecosystems?.[ecoKey];
  if (eco) {
   priceId = billingOrMode === 'annual' ? eco.stripePriceAnnual : eco.stripePriceMonthly;
   checkoutMode = 'subscription';
   metadata = { bundle: ecoKey, productType: 'ecosystem_bundle' };
  }
 }

 // Check MCP class pricing (e.g. 'mcp_lvp', 'mcp_mvp', 'mcp_hvp')
 if (!priceId && productKey.startsWith('mcp_')) {
  const cls = productKey.replace('mcp_', '');
  const mcpClass = CSGA_PRICING.mcpClassification?.[cls];
  if (mcpClass) {
   priceId = billingOrMode === 'annual' ? mcpClass.stripePriceAnnual : mcpClass.stripePriceMonthly;
   checkoutMode = 'subscription';
   metadata = { mcpClass: cls, productType: 'mcp_individual' };
  }
 }

 // Check COBOL Bridge tiers
 if (!priceId && productKey.startsWith('cobol_')) {
  const tier = productKey.replace('cobol_', '');
  const cobol = CSGA_PRICING.cobolBridge?.[tier];
  if (cobol) {
   priceId = billingOrMode === 'annual' ? cobol.stripePriceAnnual : cobol.stripePriceMonthly;
   checkoutMode = 'subscription';
   metadata = { cobolTier: tier, productType: 'cobol_bridge' };
  }
 }

 // Check CASA certifications (one-time payments)
 if (!priceId && productKey.startsWith('casa_')) {
  const level = productKey.replace('casa_', '');
  const CASA = CSGA_PRICING.casaCertification?.[level];
  if (CASA) {
   priceId = CASA.stripePrice;
   checkoutMode = 'payment';
   metadata = { casaLevel: level, productType: 'casa_certification' };
  }
 }

 // Check credit packs (one-time payments)
 if (!priceId && productKey.startsWith('credits_')) {
  const pack = productKey.replace('credits_', '');
  const credit = CSGA_PRICING.creditPacks?.[pack];
  if (credit) {
   priceId = credit.stripePrice;
   checkoutMode = 'payment';
   metadata = { pack: pack, credits: credit.credits, productType: 'credit_pack' };
  }
 }

 // If billingOrMode is 'payment', override mode (for generic one-time products)
 if (billingOrMode === 'payment') {
  checkoutMode = 'payment';
 }

 if (!priceId) {
  console.error('No price found for productKey:', productKey, 'billing:', billingOrMode);
  showStripeSetupGuide();
  btn.textContent = 'Try Again';
  btn.disabled = false;
  return;
 }

 // Use the csga_checkout helper from pricing-config.js if available, otherwise call API directly
 try {
  await csga_checkout(priceId, {
   mode: checkoutMode,
   trial: trialDays,
   metadata: metadata,
  });
 } catch (err) {
  console.error('Checkout error:', err);
  showStripeSetupGuide();
  btn.textContent = 'Try Again';
  btn.disabled = false;
 }
}
function showStripeSetupGuide() {
 document.getElementById('modal-content').innerHTML = `
 <div style="text-align:center">
 <div style="font-size:3rem;margin-bottom:15px"></div>
 <h2 style="font-family: 'Space Grotesk', 'Inter', system-ui, sans-serif;color:#0058A4;margin-bottom:10px" class="section-title" class="professional-title" class="professional-title" class="brand-heading">Stripe Integration Ready</h2>
 <p style="color:#666;margin-bottom:20px" class="professional-body">The checkout flow is configured. To activate live payments:</p>
 <div style="background:#f8f9fa;border-radius:12px;padding:20px;text-align:left;font-size:.9rem;line-height:1.8">
 <p class="professional-body"><strong>1.</strong> Add Stripe publishable key in <code>/js/pricing-config.js</code></p>
 <p class="professional-body"><strong>2.</strong> Create products/prices in Stripe Dashboard and add IDs to config</p>
 <p class="professional-body"><strong>3.</strong> Deploy serverless functions (<code>/api/*</code>) to Vercel</p>
 <p class="professional-body"><strong>4.</strong> Set <code>STRIPE_SECRET_KEY</code> and <code>STRIPE_WEBHOOK_SECRET</code> in Vercel env vars</p>
 </div>
 <a href="/contact" style="display:inline-block;margin-top:20px;padding:12px 30px;background:#0058A4;color:#fff;border-radius:8px;text-decoration:none;font-weight:600">Contact Us to Activate</a>
 </div>`;
}
function handleFreeSignup(e) {
 e.preventDefault();
 const btn = e.target.querySelector('button[type=submit]');
 btn.textContent = 'Creating account...';
 btn.disabled = true;
 setTimeout(() => {
  document.getElementById('modal-content').innerHTML = `
  <div style="text-align:center">
  <div style="font-size:3rem;margin-bottom:15px"></div>
  <h2 style="font-family: 'Space Grotesk', 'Inter', system-ui, sans-serif;color:#0058A4;margin-bottom:10px" class="section-title" class="professional-title" class="professional-title" class="brand-heading">Welcome to CSGA!</h2>
  <p style="color:#666;margin-bottom:20px" class="professional-body">Your free account has been registered. Check your email to verify and get started.</p>
  <a href="/dashboard" style="display:inline-block;padding:14px 30px;background:#0058A4;color:#fff;border-radius:8px;text-decoration:none;font-weight:600">Go to Dashboard</a>
  </div>`;
 }, 1500);
}
function handleEnterpriseInquiry(e) {
 e.preventDefault();
 const btn = e.target.querySelector('button[type=submit]');
 btn.textContent = 'Sending...';
 btn.disabled = true;
 setTimeout(() => {
  document.getElementById('modal-content').innerHTML = `
  <div style="text-align:center">
  <div style="font-size:3rem;margin-bottom:15px"></div>
  <h2 style="font-family: 'Space Grotesk', 'Inter', system-ui, sans-serif;color:#0058A4;margin-bottom:10px" class="section-title" class="professional-title" class="professional-title" class="brand-heading">Request Received</h2>
  <p style="color:#666;margin-bottom:20px" class="professional-body">Our enterprise team will contact you within 24 hours to discuss your requirements and schedule a demo.</p>
  <a href="/" style="display:inline-block;padding:14px 30px;background:#0058A4;color:#fff;border-radius:8px;text-decoration:none;font-weight:600">Back to Home</a>
  </div>`;
 }, 1500);
}
</script>

<!--  STICKY GUARANTEE BAR  -->
<div id="guarantee-bar" style="position:fixed;bottom:0;left:0;right:0;background:#0A1628;color:#fff;padding:12px 32px;display:none;z-index:9999;box-shadow:0 -4px 20px rgba(0,0,0,.2);">
 <div style="max-width:1200px;margin:0 auto;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px;">
  <div style="display:flex;align-items:center;gap:12px;">
   <span style="font-size:1.2rem;"></span>
   <span style="font-weight:600;font-size:.9rem;">30-day money-back guarantee on all paid plans</span>
   <span style="color:#64748B;font-size:.85rem;">· No credit card for trials · Cancel anytime</span>
  </div>
  <div style="display:flex;gap:10px;">
   <a href="#" onclick="handleCheckout('professional');return false" style="background:#3182ce;color:#fff;padding:8px 20px;border-radius:8px;font-weight:600;font-size:.85rem;text-decoration:none;">Start Free Trial</a>
   <button onclick="document.getElementById('guarantee-bar').style.display='none'" style="background:none;border:1px solid #334155;color:#94a3b8;padding:8px 12px;border-radius:8px;cursor:pointer;font-size:.8rem;"></button>
  </div>
 </div>
</div>
<script>
// Show guarantee bar after scrolling past hero
window.addEventListener('scroll', function() {
 var bar = document.getElementById('guarantee-bar');
 if (!bar) return;
 if (window.scrollY > 600 && !bar.dataset.dismissed) {
  bar.style.display = 'block';
 }
});
document.querySelector('#guarantee-bar button')?.addEventListener('click', function() {
 document.getElementById('guarantee-bar').dataset.dismissed = '1';
});
</script>

