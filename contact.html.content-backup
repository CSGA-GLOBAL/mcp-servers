<div id="site-header"></div>

<section class="cnt-hero">
 <div class="cnt-hero-badge">We Are Here to Help</div>
 <h1 class="professional-title professional-title" class="professional-title">Get in Touch</h1>
 <p class="professional-body">Whether you have questions about AI governance, need partnership information, or want to explore membership options, our team is ready to assist.</p>
 <div class="cnt-hero-cta" style="display: flex; gap: 16px; justify-content: center; flex-wrap: wrap; margin-top: 32px;">
  <a href="#cnt-form-card" class="btn-professional" style="display: inline-flex; align-items: center; gap: 8px; background: #3182ce; color: white; padding: 14px 28px; border-radius: 8px; text-decoration: none; font-weight: 700; font-size: 1rem; transition: all 0.25s ease; box-shadow: 0 4px 20px rgba(204, 0, 0, 0.3);"> Send Message Now</a>
  <a href="#locations" class="btn-professional" style="display: inline-flex; align-items: center; gap: 8px; background: rgba(255, 255, 255, 0.1); color: white; border: 2px solid rgba(255, 255, 255, 0.3); padding: 12px 28px; border-radius: 8px; text-decoration: none; font-weight: 600; font-size: 1rem; transition: all 0.25s ease; backdrop-filter: blur(10px);"> Our Offices</a>
 </div>
</section>

<section class="cnt-section">
 <div class="cnt-inner">
 <div class="cnt-grid">
 <div class="card-professional">
 <h2 class="professional-title professional-title" class="professional-title">Send Us a Message</h2>
 <p class="cnt-form-sub" class="professional-body">Fill out the form below and we will get back to you within one business day.</p>
 <form onsubmit="event.preventDefault(); this.querySelector('.cnt-submit').textContent='Message Sent!'; this.querySelector('.cnt-submit').style.background='#28a745'; setTimeout(function(){ alert('Thank you for your message. Our team will respond within 24 hours.'); }, 300);">
 <div class="cnt-form-row">
 <div class="cnt-fg">
 <label for="cnt-fname">First Name *</label>
 <input type="text" id="cnt-fname" name="fname" required placeholder="John">
 </div>
 <div class="cnt-fg">
 <label for="cnt-lname">Last Name *</label>
 <input type="text" id="cnt-lname" name="lname" required placeholder="Smith">
 </div>
 </div>
 <div class="cnt-form-row">
 <div class="cnt-fg">
 <label for="cnt-email">Email Address *</label>
 <input type="email" id="cnt-email" name="email" required placeholder="john@company.com">
 </div>
 <div class="cnt-fg">
 <label for="cnt-org">Organisation</label>
 <input type="text" id="cnt-org" name="org" placeholder="Company name">
 </div>
 </div>
 <div class="cnt-fg">
 <label for="cnt-dept">Department / Enquiry Type *</label>
 <select id="cnt-dept" name="dept" required>
 <option value="">Select a department...</option>
 <option value="general">General Enquiry</option>
 <option value="membership">Membership &amp; Pricing</option>
 <option value="certification">CASA Certification</option>
 <option value="education">Education &amp; Training</option>
 <option value="defence">Defence &amp; Government</option>
 <option value="enterprise">Enterprise Solutions</option>
 <option value="research">Research &amp; Publications</option>
 <option value="events">Events &amp; Speaking</option>
 <option value="media">Media &amp; Press</option>
 <option value="careers">Careers</option>
 </select>
 </div>
 <div class="cnt-fg">
 <label for="cnt-subject">Subject *</label>
 <input type="text" id="cnt-subject" name="subject" required placeholder="How can we help?">
 </div>
 <div class="cnt-fg">
 <label for="cnt-message">Message *</label>
 <textarea id="cnt-message" name="message" required placeholder="Tell us about your needs..."></textarea>
 </div>
 <button type="submit" class="cnt-submit">Send Message</button>
 </form>
 </div>
 <div class="cnt-sidebar">
 <div class="card-professional">
 <h3 class="professional-title professional-title" class="professional-title">&#9993; General Enquiries</h3>
 <p class="professional-body"><a href="mailto:hello@csgaglobal.com">hello@csgaglobal.com</a></p>
 <div class="cnt-sub-contact">For general questions about CSGA and our services</div>
 </div>
 <div class="card-professional">
 <h3 class="professional-title professional-title" class="professional-title"><div class="dept-icon-professional">ENT</div> Enterprise &amp; Sales</h3>
 <p class="professional-body"><a href="mailto:sales@csgaglobal.com">sales@csgaglobal.com</a></p>
 <div class="cnt-sub-contact">For enterprise licensing, custom training, and bulk pricing</div>
 </div>
 <div class="card-professional">
 <h3 class="professional-title professional-title" class="professional-title"><div class="dept-icon-professional">SUP</div> Technical Support</h3>
 <p class="professional-body"><a href="mailto:support@csgaglobal.com">support@csgaglobal.com</a></p>
 <div class="cnt-sub-contact">MCP server support and platform assistance</div>
 </div>
 <div class="card-professional">
 <h3 class="professional-title professional-title" class="professional-title"><div class="dept-icon-professional">DEF</div> Defence &amp; Government</h3>
 <p class="professional-body"><a href="mailto:defence@csgaglobal.com">defence@csgaglobal.com</a></p>
 <div class="cnt-sub-contact">Five Eyes partnerships and classified programmes</div>
 </div>
 <div class="card-professional">
 <h3 class="professional-title professional-title" class="professional-title"><div class="dept-icon-professional">MED</div> Media &amp; Press</h3>
 <p class="professional-body"><a href="mailto:media@csgaglobal.com">media@csgaglobal.com</a></p>
 <div class="cnt-sub-contact">Press enquiries, interviews, and media kits</div>
 </div>
 </div>
 </div>
 </div>
</section>

<section class="cnt-section alt">
 <div class="cnt-inner">
 <div style="text-align: center;">
 <div class="cnt-section-badge">Departments</div>
 <h2 class="professional-title professional-title" class="professional-title">Reach the Right Team</h2>
 <p class="cnt-section-sub" style="text-align: center; margin-left: auto; margin-right: auto;" class="professional-body">Each department has a dedicated team ready to help with your specific needs.</p>
 </div>
 <div class="cnt-depts">
 <div class="cnt-dept">
 <div class="cnt-dept-icon"><div class="dept-icon-professional">EDU</div></div>
 <h3 class="professional-title professional-title" class="professional-title">Education &amp; Training</h3>
 <p class="professional-body">MOOCs, workshops, CASA certification preparation, and professional development programmes.</p>
 <a href="mailto:education@csgaglobal.com">education@csgaglobal.com</a>
 </div>
 <div class="cnt-dept">
 <div class="cnt-dept-icon"><div class="dept-icon-professional">RES</div></div>
 <h3 class="professional-title professional-title" class="professional-title">Research &amp; Standards</h3>
 <p class="professional-body">CSOAI framework development, research collaboration, academic partnerships, and publications.</p>
 <a href="mailto:research@csgaglobal.com">research@csgaglobal.com</a>
 </div>
 <div class="cnt-dept">
 <div class="cnt-dept-icon"><div class="dept-icon-professional">MBR</div></div>
 <h3 class="professional-title professional-title" class="professional-title">Membership Services</h3>
 <p class="professional-body">Account management, tier upgrades, community access, and member benefits enquiries.</p>
 <a href="mailto:members@csgaglobal.com">members@csgaglobal.com</a>
 </div>
 <div class="cnt-dept">
 <div class="cnt-dept-icon"><div class="dept-icon-professional">VET</div></div>
 <h3 class="professional-title professional-title" class="professional-title">Veterans Programme</h3>
 <p class="professional-body">Military transition support, veteran-specific scholarships, and defence career pathways.</p>
 <a href="mailto:veterans@csgaglobal.com">veterans@csgaglobal.com</a>
 </div>
 <div class="cnt-dept">
 <div class="cnt-dept-icon"><div class="dept-icon-professional">MCP</div></div>
 <h3 class="professional-title professional-title" class="professional-title">MCP Server Platform</h3>
 <p class="professional-body">Technical implementation, server deployment, API access, and integration support.</p>
 <a href="mailto:mcp@csgaglobal.com">mcp@csgaglobal.com</a>
